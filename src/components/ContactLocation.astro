---

---

<section class="location">
  <!-- Full-width image with overlay -->
  <div class="location-visual">
    <div class="location-img-wrapper">
      <img
        src="/visit-our-kremmling-shop-bg.webp"
        alt="Highway cutting through Colorado mountains toward Kremmling"
        class="location-bg-img"
        width="1440"
        height="700"
        loading="lazy"
      />
    </div>
    <div class="location-overlay"></div>

    <!-- Blue accent strip — top edge -->
    <div class="location-accent-top"></div>

    <!-- Content positioned over image -->
    <div class="location-content">
      <div class="location-content-inner">

        <!-- Left: Elevation badge + invitation -->
        <div class="location-invite scroll-reveal">
          <div class="invite-elevation">
            <span class="elevation-number">7,364</span>
            <span class="elevation-unit">Feet</span>
          </div>
          <div class="invite-text">
            <p class="section-label">Kremmling, Colorado</p>
            <h2 class="invite-headline">Come See <br /><span class="headline-accent">the Shop.</span></h2>
            <p class="invite-sub">We're not behind a desk in Denver. We're up in the mountains, fabricating metal where the air is thin and the standards are high. Drop by, we'll show you around.</p>
          </div>
        </div>

        <!-- Right: Address card -->
        <div class="location-card scroll-reveal" style="--delay: 0.2s">
          <div class="card-accent"></div>
          <div class="card-inner">
            <div class="card-address">
              <span class="card-label">Shop Address</span>
              <a href="https://maps.google.com/?q=5871+Co+Hwy+22+Kremmling+CO+80459" target="_blank" rel="noopener" class="card-address-text">
                5871 Co Hwy 22<br />Kremmling, CO 80459
              </a>
            </div>
            <div class="card-divider"></div>
            <div class="card-details">
              <div class="card-detail-row">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>Mon - Sat · 7:30A - 5:30P</span>
              </div>
              <div class="card-detail-row">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                <a href="tel:9702812982">(970) 281-2982</a>
              </div>
            </div>
            <a href="https://maps.google.com/?q=5871+Co+Hwy+22+Kremmling+CO+80459" target="_blank" rel="noopener" class="card-directions">
              <span class="card-directions-text">Get Directions</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

</section>



<style>
  /* ===========================
     Location Section
     =========================== */
  .location {
    background: var(--bg);
    position: relative;
  }

  /* ===========================
     Visual — Full-width image block
     =========================== */
  .location-visual {
    position: relative;
    min-height: 560px;
    overflow: hidden;
  }

  .location-img-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .location-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    transition: transform 8s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .location-visual:hover .location-bg-img {
    transform: scale(1.05);
  }

  .location-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, rgba(23, 23, 23, 0.92) 0%, rgba(23, 23, 23, 0.78) 50%, rgba(23, 23, 23, 0.65) 100%),
      linear-gradient(to bottom, rgba(23, 23, 23, 1) 0%, transparent 15%, transparent 85%, rgba(23, 23, 23, 1) 100%);
    z-index: 1;
  }

  /* Top accent strip */
  .location-accent-top {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--blue-primary) 0%, var(--blue-accent) 50%, var(--blue-primary) 100%);
    z-index: 3;
  }

  /* ===========================
     Content Layer
     =========================== */
  .location-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    min-height: 560px;
  }

  .location-content-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 80px 100px;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  /* ===========================
     Invitation (Left)
     =========================== */
  .location-invite {
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }

  /* Elevation badge */
  .invite-elevation {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 20px;
    border: 1px solid rgba(36, 93, 167, 0.3);
    background: rgba(36, 93, 167, 0.08);
    flex-shrink: 0;
    transition: border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
                background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .invite-elevation:hover {
    border-color: rgba(36, 93, 167, 0.5);
    background: rgba(36, 93, 167, 0.12);
  }

  .elevation-number {
    font-family: var(--font-heading);
    font-size: 44px;
    font-weight: 700;
    color: var(--blue-accent);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .elevation-unit {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--white-muted);
    margin-top: 4px;
  }

  /* Invite text */
  .section-label {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 20px;
  }

  .headline-accent {
    color: var(--blue-accent);
  }

  .invite-headline {
    font-family: var(--font-heading);
    font-size: 64px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 105%;
    margin-bottom: 20px;
  }

  .invite-sub {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 170%;
    max-width: 520px;
  }

  /* ===========================
     Address Card (Right)
     =========================== */
  .location-card {
    display: flex;
    align-self: center;
  }

  .card-accent {
    width: 4px;
    background: var(--blue-primary);
    flex-shrink: 0;
    transition: background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .location-card:hover .card-accent {
    background: var(--blue-accent);
  }

  .card-inner {
    padding: 36px 32px;
    background: rgba(23, 23, 23, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(232, 232, 232, 0.08);
    border-left: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
                box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    flex: 1;
  }

  .location-card:hover .card-inner {
    border-color: rgba(36, 93, 167, 0.3);
    box-shadow: 0 0 40px rgba(36, 93, 167, 0.1);
  }

  .card-label {
    display: block;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blue-accent);
    margin-bottom: 12px;
  }

  .card-address-text {
    display: block;
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 400;
    color: var(--white-full);
    line-height: 130%;
    text-decoration: none;
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-address-text:hover {
    color: var(--blue-accent);
  }

  .card-divider {
    width: 100%;
    height: 1px;
    background: rgba(232, 232, 232, 0.12);
    margin: 24px 0;
  }

  .card-details {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .card-detail-row {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--white-muted);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
  }

  .card-detail-row svg {
    color: var(--blue-accent);
    flex-shrink: 0;
  }

  .card-detail-row a {
    color: var(--white-muted);
    text-decoration: none;
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-detail-row a:hover {
    color: var(--blue-accent);
  }

  .card-directions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 24px;
    color: var(--white);
    text-decoration: none;
    padding: 14px 0 0;
    border-top: 1px solid rgba(232, 232, 232, 0.08);
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-directions:hover {
    color: var(--blue-accent);
  }

  .card-directions-text {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .card-directions svg {
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
    flex-shrink: 0;
  }

  .card-directions:hover svg {
    transform: translate(3px, -3px);
  }


  /* ===========================
     Responsive — 1200px
     =========================== */
  @media (max-width: 1200px) {
    .location-visual {
      min-height: 500px;
    }

    .location-content {
      min-height: 500px;
    }

    .location-content-inner {
      padding: 72px 60px;
      grid-template-columns: 1fr 340px;
      gap: 60px;
    }

    .invite-headline {
      font-size: 52px;
    }

    .invite-sub {
      font-size: 17px;
    }

    .elevation-number {
      font-size: 38px;
    }

    .invite-elevation {
      padding: 20px 16px;
    }

    .location-invite {
      gap: 36px;
    }

    .card-address-text {
      font-size: 24px;
    }

  }

  /* ===========================
     Responsive — 1024px
     =========================== */
  @media (max-width: 1024px) {
    .location-visual {
      min-height: 480px;
    }

    .location-content {
      min-height: 480px;
    }

    .location-content-inner {
      padding: 60px 40px;
      grid-template-columns: 1fr 300px;
      gap: 48px;
    }

    .invite-headline {
      font-size: 44px;
    }

    .invite-sub {
      font-size: 16px;
      max-width: 400px;
    }

    .elevation-number {
      font-size: 34px;
    }

    .invite-elevation {
      padding: 18px 14px;
    }

    .location-invite {
      gap: 28px;
    }

    .section-label {
      font-size: 18px;
      margin-bottom: 16px;
    }

    .card-inner {
      padding: 28px 24px;
    }

    .card-address-text {
      font-size: 22px;
    }

    .card-label {
      font-size: 12px;
    }

    .card-detail-row {
      font-size: 14px;
    }

    .card-directions-text {
      font-size: 14px;
    }

  }

  /* ===========================
     Responsive — 768px
     =========================== */
  @media (max-width: 768px) {
    .location-visual {
      min-height: auto;
    }

    .location-content {
      min-height: auto;
    }

    .location-content-inner {
      padding: 48px 24px;
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .location-overlay {
      background:
        linear-gradient(180deg, rgba(23, 23, 23, 0.95) 0%, rgba(23, 23, 23, 0.85) 50%, rgba(23, 23, 23, 0.95) 100%);
    }

    /* Stack invitation vertically */
    .location-invite {
      flex-direction: column;
      gap: 20px;
      align-items: flex-start;
    }

    /* Elevation badge goes horizontal on mobile */
    .invite-elevation {
      flex-direction: row;
      gap: 12px;
      align-items: baseline;
      padding: 14px 20px;
    }

    .elevation-number {
      font-size: 32px;
    }

    .elevation-unit {
      font-size: 13px;
      margin-top: 0;
    }

    .invite-headline {
      font-size: 36px;
      margin-bottom: 14px;
    }

    /* Remove <br> on mobile — let it flow naturally */
    .invite-headline br {
      display: none;
    }

    .invite-sub {
      font-size: 15px;
      max-width: 100%;
      line-height: 165%;
    }

    .section-label {
      font-size: 18px;
      margin-bottom: 10px;
    }

    /* Compress scroll-reveal for mobile — shorter travel, faster */
    .location .scroll-reveal {
      transform: translateY(14px);
      transition-duration: 0.45s;
      transition-delay: 0s !important;
    }

    .location .scroll-reveal.revealed {
      transform: none;
    }

    /* Card goes full-width */
    .location-card {
      flex-direction: column;
    }

    .card-accent {
      width: 100%;
      height: 3px;
    }

    .card-inner {
      border: 1px solid rgba(232, 232, 232, 0.1);
      border-top: none;
      padding: 24px 20px;
    }

    .card-address-text {
      font-size: 22px;
    }

    .card-divider {
      margin: 20px 0;
    }

    /* Phone number — fat tap target on mobile */
    .card-detail-row a {
      padding: 4px 0;
      display: inline-block;
    }

    /* Get Directions — proper button-like CTA on mobile */
    .card-directions {
      margin-top: 20px;
      justify-content: center;
      padding: 16px 20px;
      border-top: 1px solid rgba(232, 232, 232, 0.08);
      border-bottom: none;
      background: rgba(36, 93, 167, 0.08);
      border: 1px solid rgba(36, 93, 167, 0.25);
      transition: background 0.25s ease, border-color 0.25s ease, color 0.3s ease;
    }

    .card-directions:active {
      background: rgba(36, 93, 167, 0.2);
      border-color: rgba(36, 93, 167, 0.5);
      color: var(--blue-accent);
    }


    .location-accent-top {
      height: 3px;
    }

    /* Disable hover-zoom on touch */
    .location-visual:hover .location-bg-img {
      transform: none;
    }
  }

  /* ===========================
     Responsive — 480px
     =========================== */
  @media (max-width: 480px) {
    .location-content-inner {
      padding: 32px 16px;
      gap: 22px;
    }

    .location-invite {
      gap: 16px;
    }

    .invite-elevation {
      padding: 12px 16px;
    }

    .elevation-number {
      font-size: 28px;
    }

    .elevation-unit {
      font-size: 12px;
    }

    .invite-headline {
      font-size: 28px;
      margin-bottom: 12px;
    }

    .invite-sub {
      font-size: 14px;
      line-height: 160%;
    }

    .section-label {
      font-size: 16px;
      margin-bottom: 8px;
    }

    .card-inner {
      padding: 20px 16px;
    }

    .card-address-text {
      font-size: 20px;
    }

    .card-label {
      font-size: 11px;
      margin-bottom: 10px;
    }

    .card-detail-row {
      font-size: 14px;
      gap: 10px;
      padding: 3px 0;
    }

    .card-detail-row svg {
      width: 16px;
      height: 16px;
    }

    .card-divider {
      margin: 16px 0;
    }

    .card-directions {
      margin-top: 16px;
      padding: 14px 16px;
    }

    .card-directions-text {
      font-size: 13px;
    }

    /* Even shorter reveal travel at small screens */
    .location .scroll-reveal {
      transform: translateY(10px);
      transition-duration: 0.4s;
    }

    .location .scroll-reveal.revealed {
      transform: none;
    }
  }
</style>
