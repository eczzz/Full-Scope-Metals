<section class="who-we-are">
  <div class="who-inner">
    <!-- Top Row -->
    <div class="top-row">
      <div class="top-left scroll-reveal">
        <p class="section-label">Who We Are</p>
        <h2 class="section-headline">
          Colorado-Built.<br />
          <span class="headline-indent">Contractor-Proven.</span>
        </h2>
      </div>

      <div class="nav-arrows scroll-reveal" style="--delay: 0.15s">
        <button class="nav-btn nav-btn-outline" aria-label="Previous">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M19 12H5M5 12L11 18M5 12L11 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="nav-btn nav-btn-outline" aria-label="Next">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Cards Row -->
    <div class="cards-grid">
      <!-- Card 01 -->
      <div class="card scroll-reveal" style="--delay: 0.1s">
        <svg class="card-arrow" width="36" height="36" viewBox="0 0 24 24" fill="none">
          <path d="M10 4H20V14" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M6 8H16V18" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="card-number">01.</span>
        <h3 class="card-title">We've Been in Your Boots</h3>
        <p class="card-body">Full Scope Metals was born from years of installing metal roofing and dealing with suppliers who didn't understand urgency, quality, or what it takes to finish a job.</p>
      </div>

      <!-- Card 02 -->
      <div class="card scroll-reveal" style="--delay: 0.2s">
        <svg class="card-arrow" width="36" height="36" viewBox="0 0 24 24" fill="none">
          <path d="M10 4H20V14" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M6 8H16V18" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="card-number">02.</span>
        <h3 class="card-title">Fabricated in Colorado</h3>
        <p class="card-body">Every panel, trim, and accessory is manufactured out of our Western Colorado shop. When you call us on a Friday afternoon, we pick up.</p>
      </div>

      <!-- Card 03 -->
      <div class="card scroll-reveal" style="--delay: 0.3s">
        <svg class="card-arrow" width="36" height="36" viewBox="0 0 24 24" fill="none">
          <path d="M10 4H20V14" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M6 8H16V18" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="card-number">03.</span>
        <h3 class="card-title">Your Project, Your Spec</h3>
        <p class="card-body">Every panel, trim, and accessory is manufactured out of our Western Colorado shop. When you call us on a Friday afternoon, we pick up.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .who-we-are {
    background: var(--bg);
    padding: 80px 0;
    overflow: hidden;
  }

  .who-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
  }

  /* Top Row */
  .top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
  }

  .section-headline {
    font-family: var(--font-heading);
    font-size: 72px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 110%;
  }

  .headline-indent {
    display: inline-block;
    padding-left: 200px;
  }

  .nav-arrows {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
    margin-top: 84px;
  }

  .nav-btn {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .nav-btn-outline {
    background: transparent;
    border: 1px solid var(--white);
    color: var(--white);
  }

  .nav-btn-outline:hover {
    background: var(--blue-accent);
    border-color: var(--blue-accent);
    color: var(--black);
  }

  /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 60px;
    margin-left: -80px;
    margin-right: -80px;
  }

  .card {
    position: relative;
    border: 1px solid var(--white);
    background: transparent;
    padding: 40px;
    display: flex;
    flex-direction: column;
    min-height: 320px;
    transition: background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-arrow {
    position: absolute;
    top: 28px;
    right: 28px;
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-number {
    font-family: var(--font-heading);
    font-size: 64px;
    font-weight: 400;
    color: var(--white);
    line-height: 1;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-top: 24px;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-body {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
    line-height: 150%;
    margin-top: 16px;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-arrow path {
    transition: stroke 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  /* Card Hover */
  .card:hover {
    background: var(--blue-accent);
    border-color: var(--blue-accent);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 162, 233, 0.15);
  }

  .card:hover .card-arrow {
    transform: translate(4px, -4px);
  }

  .card:hover .card-number {
    color: var(--black);
  }

  .card:hover .card-title {
    color: var(--black);
  }

  .card:hover .card-body {
    color: var(--black);
  }

  .card:hover .card-arrow path {
    stroke: var(--black);
  }

  /* 1200px */
  @media (max-width: 1200px) {
    .who-inner {
      padding: 0 60px;
    }

    .section-headline {
      font-size: 60px;
    }

    .headline-indent {
      padding-left: 140px;
    }

    .cards-grid {
      margin-left: 0;
      margin-right: 0;
    }
  }

  /* 1024px — stack to single column */
  @media (max-width: 1024px) {
    .who-we-are {
      padding: 64px 0;
    }

    .who-inner {
      padding: 0 40px;
    }

    .top-row {
      flex-direction: column;
      gap: 24px;
    }

    .section-headline {
      font-size: 48px;
    }

    .headline-indent {
      padding-left: 100px;
    }

    .nav-arrows {
      flex-direction: row;
      margin-top: 0;
    }

    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
      margin-left: 0;
      margin-right: 0;
    }

    .card {
      padding: 32px;
      min-height: 280px;
    }

    .card-number {
      font-size: 48px;
    }

    .card-title {
      font-size: 26px;
    }

    .card-body {
      font-size: 18px;
    }
  }

  /* 768px */
  @media (max-width: 768px) {
    .who-we-are {
      padding: 48px 0;
    }

    .who-inner {
      padding: 0 24px;
    }

    .section-headline {
      font-size: 36px;
    }

    .headline-indent {
      padding-left: 40px;
    }

    .section-label {
      font-size: 18px;
    }

    .nav-btn {
      width: 48px;
      height: 48px;
    }

    .nav-btn svg {
      width: 32px;
      height: 32px;
    }

    .cards-grid {
      grid-template-columns: 1fr;
      margin-top: 40px;
      gap: 16px;
    }

    .card {
      padding: 28px;
      min-height: auto;
    }

    .card-number {
      font-size: 42px;
    }

    .card-title {
      font-size: 24px;
      margin-top: 16px;
    }

    .card-body {
      font-size: 16px;
    }
  }

  /* 480px */
  @media (max-width: 480px) {
    .who-we-are {
      padding: 40px 0;
    }

    .who-inner {
      padding: 0 16px;
    }

    .section-headline {
      font-size: 28px;
    }

    .headline-indent {
      padding-left: 24px;
    }

    .section-label {
      font-size: 16px;
      margin-bottom: 12px;
    }

    .nav-btn {
      width: 44px;
      height: 44px;
    }

    .nav-btn svg {
      width: 28px;
      height: 28px;
    }

    .cards-grid {
      margin-top: 32px;
      gap: 12px;
    }

    .card {
      padding: 24px;
    }

    .card-number {
      font-size: 36px;
    }

    .card-title {
      font-size: 20px;
      margin-top: 12px;
    }

    .card-body {
      font-size: 14px;
      margin-top: 12px;
    }

    .card-arrow {
      top: 20px;
      right: 20px;
      width: 28px;
      height: 28px;
    }
  }
</style>
