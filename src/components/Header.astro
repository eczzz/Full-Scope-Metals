<header class="header" id="header">
  <div class="header-inner">
    <div class="header-top">
      <a href="/" class="logo-link">
        <img
          src="/Full-Scope-Metals-logo.webp"
          alt="Full Scope Metals"
          width="127"
          height="69"
        />
      </a>

      <nav class="nav">
        <a href="/" class="nav-link">Home</a>
        <a href="/about" class="nav-link">About</a>
        <div class="nav-dropdown">
          <a href="/projects" class="nav-link nav-link-dropdown">
            Projects
            <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <a href="/projects" class="nav-link">Projects</a>
        <a href="/contact" class="nav-link">Contact</a>
      </nav>

      <a href="/contact" class="cta-button">Get a Quote</a>

      <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle navigation">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>
</header>

<!-- Full-Screen Mobile Menu -->
<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu-accent-top"></div>

  <div class="mobile-menu-inner">
    <nav class="mobile-nav">
      <a href="/" class="mobile-nav-item" style="--i: 0">
        <span class="mobile-nav-number">01</span>
        <span class="mobile-nav-text">Home</span>
        <svg class="mobile-nav-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/about" class="mobile-nav-item" style="--i: 1">
        <span class="mobile-nav-number">02</span>
        <span class="mobile-nav-text">About</span>
        <svg class="mobile-nav-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/products" class="mobile-nav-item" style="--i: 2">
        <span class="mobile-nav-number">03</span>
        <span class="mobile-nav-text">Products</span>
        <svg class="mobile-nav-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/projects" class="mobile-nav-item" style="--i: 3">
        <span class="mobile-nav-number">04</span>
        <span class="mobile-nav-text">Projects</span>
        <svg class="mobile-nav-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/contact" class="mobile-nav-item" style="--i: 4">
        <span class="mobile-nav-number">05</span>
        <span class="mobile-nav-text">Contact</span>
        <svg class="mobile-nav-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>

    <div class="mobile-menu-bottom" style="--i: 5">
      <a href="/contact" class="mobile-cta">Get a Quote</a>
      <div class="mobile-info">
        <a href="tel:9702812982">(970) 281-2982</a>
        <span class="mobile-info-dot"></span>
        <p>Kremmling, CO</p>
      </div>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('header');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    toggle?.classList.toggle('active');
    header?.classList.toggle('menu-open');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close menu on nav link click
  document.querySelectorAll('.mobile-nav-item, .mobile-cta').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.remove('open');
      toggle?.classList.remove('active');
      header?.classList.remove('menu-open');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  /* ===== Desktop Header ===== */
  .header {
    background: var(--bg);
    width: 100%;
  }

  .header-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 24px 126px 20px;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-link {
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .logo-link img {
    width: 127px;
    height: 69px;
    transition: transform 0.3s ease, filter 0.3s ease;
  }

  .logo-link:hover img {
    transform: scale(1.05);
    filter: brightness(1.15);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-muted);
    transition: color 0.3s ease;
    position: relative;
    padding-bottom: 4px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--blue-accent);
    transition: width 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .nav-link:hover {
    color: var(--white-full);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-link-dropdown {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .chevron {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .nav-link-dropdown:hover .chevron {
    transform: translateY(2px);
  }

  .cta-button {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    border: 1px solid var(--white);
    background: transparent;
    padding: 16px 35px;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: var(--white);
    z-index: -1;
    transition: width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-button:hover {
    color: var(--bg);
  }

  .cta-button:hover::before {
    width: 100%;
  }

  /* Hamburger (hidden on desktop) */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .bar {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    transition: transform 0.2s ease;
  }

  /* Mobile Menu (hidden on desktop) */
  .mobile-menu {
    display: none;
  }

  /* ===== 1200px ===== */
  @media (max-width: 1200px) {
    .header-inner {
      padding: 24px 60px 20px;
    }

    .nav {
      gap: 32px;
    }
  }

  /* ===== 1024px ===== */
  @media (max-width: 1024px) {
    .header-inner {
      padding: 24px 40px 20px;
    }

    .nav {
      gap: 24px;
    }

    .nav-link {
      font-size: 16px;
    }

    .cta-button {
      font-size: 16px;
      padding: 12px 24px;
    }
  }

  /* ===== 768px — Mobile Menu ===== */
  @media (max-width: 768px) {
    .header {
      position: sticky;
      top: 0;
      z-index: 1001;
      transition: background 0.3s ease;
    }

    .header-inner {
      padding: 16px 24px;
    }

    /* Hide desktop nav + CTA */
    .nav {
      display: none;
    }

    .cta-button {
      display: none;
    }

    /* Hamburger */
    .mobile-toggle {
      display: flex;
      position: relative;
      z-index: 1002;
      width: 40px;
      height: 40px;
      align-items: center;
      justify-content: center;
      gap: 0;
      padding: 0;
    }

    .bar {
      position: absolute;
      width: 26px;
      height: 2px;
      background: var(--white);
      transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
                  opacity 0.25s ease;
    }

    .bar:nth-child(1) {
      transform: translateY(-8px);
    }

    .bar:nth-child(2) {
      transform: translateY(0);
    }

    .bar:nth-child(3) {
      transform: translateY(8px);
    }

    .mobile-toggle.active .bar:nth-child(1) {
      transform: rotate(45deg);
      background: var(--white-full);
    }

    .mobile-toggle.active .bar:nth-child(2) {
      opacity: 0;
      transform: scaleX(0);
    }

    .mobile-toggle.active .bar:nth-child(3) {
      transform: rotate(-45deg);
      background: var(--white-full);
    }

    /* ===== Full-Screen Mobile Menu ===== */
    .mobile-menu {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      height: 100dvh;
      background: var(--bg);
      z-index: 1000;
      clip-path: inset(0 0 100% 0);
      transition: clip-path 0.6s cubic-bezier(0.76, 0, 0.24, 1);
    }

    .mobile-menu.open {
      clip-path: inset(0 0 0 0);
    }

    /* Blue gradient accent line at top */
    .mobile-menu-accent-top {
      position: absolute;
      top: 0;
      left: 0;
      height: 3px;
      width: 0;
      background: linear-gradient(90deg, var(--blue-primary), var(--blue-accent));
      transition: width 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.3s;
      z-index: 1;
    }

    .mobile-menu.open .mobile-menu-accent-top {
      width: 100%;
    }

    .mobile-menu-inner {
      display: flex;
      flex-direction: column;
      height: 100%;
      padding: 110px 32px 40px;
      overflow-y: auto;
    }

    /* Nav Items */
    .mobile-nav {
      display: flex;
      flex-direction: column;
      flex: 1;
      justify-content: center;
    }

    .mobile-nav-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px 0;
      border-bottom: 1px solid rgba(232, 232, 232, 0.06);
      text-decoration: none;
      position: relative;
      opacity: 0;
      transform: translateX(30px);
      transition: opacity 0.5s cubic-bezier(0.25, 0.1, 0.25, 1),
                  transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
      transition-delay: calc(0.2s + var(--i) * 0.07s);
    }

    .mobile-menu.open .mobile-nav-item {
      opacity: 1;
      transform: translateX(0);
    }

    /* Blue underline sweep on hover */
    .mobile-nav-item::before {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--blue-primary), var(--blue-accent));
      transition: width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .mobile-nav-item:hover::before,
    .mobile-nav-item:active::before {
      width: 100%;
    }

    .mobile-nav-number {
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      color: var(--blue-accent);
      min-width: 22px;
      padding-top: 4px;
      align-self: flex-start;
    }

    .mobile-nav-text {
      font-family: var(--font-heading);
      font-size: clamp(36px, 7vw, 52px);
      font-weight: 400;
      text-transform: uppercase;
      color: var(--white);
      line-height: 1.1;
      flex: 1;
      transition: color 0.3s ease, transform 0.3s ease;
    }

    .mobile-nav-item:hover .mobile-nav-text,
    .mobile-nav-item:active .mobile-nav-text {
      color: var(--white-full);
      transform: translateX(4px);
    }

    .mobile-nav-arrow {
      color: rgba(232, 232, 232, 0.15);
      flex-shrink: 0;
      transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s ease;
    }

    .mobile-nav-item:hover .mobile-nav-arrow,
    .mobile-nav-item:active .mobile-nav-arrow {
      color: var(--blue-accent);
      transform: translateX(4px);
    }

    /* Bottom Section */
    .mobile-menu-bottom {
      padding-top: 28px;
      border-top: 1px solid rgba(232, 232, 232, 0.06);
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s cubic-bezier(0.25, 0.1, 0.25, 1),
                  transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
      transition-delay: calc(0.2s + var(--i) * 0.07s);
    }

    .mobile-menu.open .mobile-menu-bottom {
      opacity: 1;
      transform: translateY(0);
    }

    .mobile-cta {
      display: inline-block;
      font-family: var(--font-heading);
      font-size: 18px;
      font-weight: 400;
      text-transform: uppercase;
      color: var(--white);
      border: 1px solid var(--white);
      padding: 14px 32px;
      position: relative;
      overflow: hidden;
      z-index: 1;
      transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .mobile-cta::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 0;
      height: 100%;
      background: var(--blue-accent);
      z-index: -1;
      transition: width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .mobile-cta:hover {
      color: var(--black);
    }

    .mobile-cta:hover::before {
      width: 100%;
    }

    .mobile-info {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 20px;
    }

    .mobile-info a,
    .mobile-info p {
      font-family: var(--font-body);
      font-size: 13px;
      font-weight: 400;
      color: var(--white-muted);
      transition: color 0.3s ease;
    }

    .mobile-info a:hover {
      color: var(--blue-accent);
    }

    .mobile-info-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--white-muted);
      flex-shrink: 0;
    }
  }

  /* ===== 480px ===== */
  @media (max-width: 480px) {
    .header-inner {
      padding: 12px 16px;
    }

    .logo-link img {
      width: 100px;
      height: auto;
    }

    .mobile-menu-inner {
      padding: 90px 24px 32px;
    }

    .mobile-nav-item {
      padding: 16px 0;
      gap: 12px;
    }

    .mobile-nav-number {
      font-size: 10px;
      min-width: 18px;
    }

    .mobile-cta {
      font-size: 16px;
      padding: 12px 28px;
    }

    .mobile-info {
      margin-top: 16px;
    }

    .mobile-info a,
    .mobile-info p {
      font-size: 12px;
    }
  }
</style>
