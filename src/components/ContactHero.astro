---

---

<section class="contact-hero">
  <div class="contact-hero-bg">
    <img
      src="/full-scope-contact-hero-bg.webp"
      alt="Full Scope Metals fabrication facility"
      class="contact-hero-bg-img"
      width="1440"
      height="600"
      fetchpriority="high"
    />
    <div class="contact-hero-overlay"></div>
  </div>

  <div class="contact-hero-inner">
    <!-- Left: Headline Block -->
    <div class="hero-primary">
      <p class="section-label hero-fade-up" style="--hero-delay: 0.1s">Contact</p>

      <h1 class="hero-headline hero-fade-up" style="--hero-delay: 0.3s">
        <span class="headline-accent">We Pick Up</span><br />the Phone.
      </h1>

      <p class="hero-sub hero-fade-up" style="--hero-delay: 0.5s">
        Real people, real answers. Call us directly or send a quote request and we aim to get back to you fast.
      </p>
    </div>

    <!-- Right: Direct Contact Strip -->
    <div class="hero-contact-strip hero-fade-up" style="--hero-delay: 0.6s">
      <div class="strip-accent"></div>
      <div class="strip-content">
        <span class="strip-label">Call Direct</span>
        <a href="tel:9702812982" class="strip-phone">(970) 281-2982</a>
        <div class="strip-divider"></div>
        <span class="strip-hours">Mon - Sat &nbsp;·&nbsp; 7:30A - 5:30P</span>
        <a href="#contact-form" class="strip-cta">
          <span class="strip-cta-text">Or Send a Quote Request</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 5V19M12 19L6 13M12 19L18 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Blue Divider -->
  <div class="hero-divider"></div>
</section>

<script>
  document.querySelector('.strip-cta')?.addEventListener('click', (e) => {
    e.preventDefault();
    const target = document.querySelector('#contact-form');
    if (target) {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
</script>

<style>
  /* ===========================
     Hero Load Animations
     =========================== */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes dividerExpand {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  @keyframes stripSlideIn {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .hero-fade-up {
    opacity: 0;
    animation: heroFadeUp 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: var(--hero-delay, 0s);
  }

  /* ===========================
     Contact Hero Layout
     =========================== */
  .contact-hero {
    position: relative;
    background: var(--bg);
    overflow: hidden;
  }

  /* Background Image */
  .contact-hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .contact-hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .contact-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, rgba(23, 23, 23, 0.95) 0%, rgba(23, 23, 23, 0.88) 50%, rgba(23, 23, 23, 0.75) 100%),
      linear-gradient(to bottom, rgba(23, 23, 23, 1) 0%, transparent 20%, transparent 80%, rgba(23, 23, 23, 1) 100%);
  }

  .contact-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 80px 100px 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 80px;
  }

  /* ===========================
     Primary Content (Left)
     =========================== */
  .hero-primary {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    min-width: 0;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 20px;
  }

  .headline-accent {
    color: var(--blue-accent);
  }

  /* Headline */
  .hero-headline {
    font-family: var(--font-heading);
    font-size: 80px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 105%;
    margin-bottom: 28px;
    max-width: 700px;
  }

  /* Subtext */
  .hero-sub {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 160%;
    max-width: 560px;
  }

  /* ===========================
     Contact Strip (Right)
     =========================== */
  .hero-contact-strip {
    position: relative;
    display: flex;
    align-self: center;
    flex-shrink: 0;
    width: 320px;
  }

  .strip-accent {
    width: 4px;
    background: var(--blue-primary);
    flex-shrink: 0;
    transition: background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .hero-contact-strip:hover .strip-accent {
    background: var(--blue-accent);
  }

  .strip-content {
    padding: 36px 32px;
    background: rgba(23, 23, 23, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(232, 232, 232, 0.08);
    border-left: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .hero-contact-strip:hover .strip-content {
    border-color: rgba(36, 93, 167, 0.3);
    box-shadow: 0 0 40px rgba(36, 93, 167, 0.1);
  }

  .strip-label {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blue-accent);
    margin-bottom: 8px;
  }

  .strip-phone {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 400;
    color: var(--white-full);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .strip-phone:hover {
    color: var(--blue-accent);
  }

  .strip-divider {
    width: 100%;
    height: 1px;
    background: rgba(232, 232, 232, 0.12);
    margin: 20px 0;
  }

  .strip-hours {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--white-muted);
    margin-bottom: 24px;
  }

  .strip-cta {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--white);
    text-decoration: none;
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .strip-cta:hover {
    color: var(--blue-accent);
  }

  .strip-cta-text {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .strip-cta svg {
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
    flex-shrink: 0;
  }

  .strip-cta:hover svg {
    transform: translateY(3px);
  }

  /* ===========================
     Hero Divider
     =========================== */
  .hero-divider {
    width: 100%;
    height: 18px;
    background: var(--blue-primary);
    transform-origin: left;
    transform: scaleX(0);
    animation: dividerExpand 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: 0.85s;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  /* ===========================
     Desktop BR utility
     =========================== */
  .desktop-br {
    display: inline;
  }

  /* ===========================
     Responsive — 1200px
     =========================== */
  @media (max-width: 1200px) {
    .contact-hero-inner {
      padding: 72px 60px 64px;
      gap: 60px;
    }

    .hero-contact-strip {
      width: 300px;
    }

    .hero-headline {
      font-size: 68px;
    }

    .hero-sub {
      font-size: 18px;
    }

    .strip-phone {
      font-size: 28px;
    }
  }

  /* ===========================
     Responsive — 1024px
     =========================== */
  @media (max-width: 1024px) {
    .contact-hero-inner {
      padding: 64px 40px 56px;
      gap: 48px;
    }

    .hero-contact-strip {
      width: 280px;
    }

    .hero-headline {
      font-size: 56px;
    }

    .hero-sub {
      font-size: 17px;
      max-width: 480px;
    }

    .strip-content {
      padding: 28px 24px;
    }

    .strip-phone {
      font-size: 26px;
    }

    .strip-cta-text {
      font-size: 14px;
    }
  }

  /* ===========================
     Responsive — 768px
     =========================== */
  @media (max-width: 768px) {
    /* Faster, snappier animations for mobile */
    .hero-fade-up {
      animation-duration: 0.5s;
    }

    @keyframes heroFadeUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .hero-divider {
      animation-duration: 0.5s;
      animation-delay: 0.5s;
    }

    .contact-hero-inner {
      padding: 48px 24px 40px;
      flex-direction: column;
      gap: 32px;
    }

    .hero-contact-strip {
      width: 100%;
    }

    .contact-hero-overlay {
      background:
        linear-gradient(180deg, rgba(23, 23, 23, 0.97) 0%, rgba(23, 23, 23, 0.88) 50%, rgba(23, 23, 23, 0.97) 100%);
    }

    .hero-headline {
      font-size: 44px;
      max-width: 100%;
      margin-bottom: 20px;
    }

    .hero-sub {
      font-size: 16px;
      max-width: 100%;
      line-height: 165%;
    }

    .section-label {
      font-size: 18px;
    }

    /* Strip becomes full-width card */
    .hero-contact-strip {
      flex-direction: column;
    }

    .strip-accent {
      width: 100%;
      height: 3px;
    }

    .strip-content {
      border: 1px solid rgba(232, 232, 232, 0.1);
      border-top: none;
      padding: 24px;
      text-align: center;
      align-items: center;
    }

    .strip-label {
      font-size: 12px;
      letter-spacing: 0.15em;
      margin-bottom: 12px;
    }

    /* Phone number as prominent tap target */
    .strip-phone {
      font-size: 28px;
      display: block;
      background: var(--blue-primary);
      color: var(--white-full);
      padding: 16px 24px;
      text-align: center;
      letter-spacing: 0.03em;
      transition: background 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .strip-phone:active {
      background: var(--blue-accent);
    }

    .strip-divider {
      margin: 20px 0;
      width: 48px;
      background: rgba(232, 232, 232, 0.15);
    }

    .strip-hours {
      margin-bottom: 20px;
      font-size: 14px;
    }

    /* CTA as a clear secondary action */
    .strip-cta {
      justify-content: center;
      gap: 8px;
      padding: 14px 20px;
      border: 1px solid rgba(232, 232, 232, 0.2);
      transition: border-color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1),
                  color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .strip-cta:active {
      border-color: var(--blue-accent);
      color: var(--blue-accent);
    }

    .strip-cta-text {
      font-size: 13px;
    }

    .hero-divider {
      height: 10px;
    }

    /* Compress animation delay schedule for mobile */
    .section-label.hero-fade-up { animation-delay: 0.05s; }
    .hero-headline.hero-fade-up { animation-delay: 0.15s; }
    .hero-sub.hero-fade-up { animation-delay: 0.25s; }
    .hero-contact-strip.hero-fade-up { animation-delay: 0.3s; }
  }

  /* ===========================
     Responsive — 480px
     =========================== */
  @media (max-width: 480px) {
    .contact-hero-inner {
      padding: 40px 16px 32px;
      gap: 28px;
    }

    .section-label {
      font-size: 16px;
      margin-bottom: 14px;
    }

    .hero-headline {
      font-size: 36px;
      margin-bottom: 16px;
      line-height: 108%;
    }

    .hero-sub {
      font-size: 15px;
      line-height: 160%;
    }

    .strip-content {
      padding: 20px 16px;
    }

    .strip-label {
      font-size: 11px;
      margin-bottom: 10px;
    }

    .strip-phone {
      font-size: 24px;
      padding: 14px 20px;
    }

    .strip-divider {
      margin: 16px 0;
    }

    .strip-hours {
      font-size: 13px;
      margin-bottom: 16px;
    }

    .strip-cta {
      padding: 12px 16px;
    }

    .strip-cta-text {
      font-size: 12px;
    }

    .hero-divider {
      height: 8px;
    }
  }
</style>
