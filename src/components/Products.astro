---

---

<section class="products">
  <div class="products-inner">
    <!-- Top Content -->
    <div class="top-row">
      <div class="top-left scroll-reveal">
        <p class="section-label">Products</p>
        <h2 class="section-headline">Everything Your <span class="headline-accent">Metal Roof Needs.</span></h2>
      </div>

      <div class="top-right scroll-reveal" style="--delay: 0.15s">
        <div class="top-right-sub">
          <div class="accent-bar"></div>
          <p class="top-right-subtext">Fabricated in-house and sourced<br />from trusted partners.</p>
        </div>
        <div class="explore-row">
          <p class="explore-label">Explore Products:</p>
          <div class="dropdown-wrap">
            <button class="cta-blue dropdown-toggle" aria-expanded="false" aria-haspopup="true">
              <span class="dropdown-toggle-text">Select Product</span>
              <svg class="dropdown-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="dropdown-menu" role="menu">
              <a href="/products#roof-panels" class="dropdown-item" role="menuitem">Roof Panels</a>
              <a href="/products#wall-panels" class="dropdown-item" role="menuitem">Wall Panels</a>
              <a href="/products#trims-flashing" class="dropdown-item" role="menuitem">Trims & Flashing</a>
              <a href="/products#fasteners-hardware" class="dropdown-item" role="menuitem">Fasteners & Hardware</a>
              <a href="/products#sealants-adhesives" class="dropdown-item" role="menuitem">Sealants & Adhesives</a>
              <a href="/products#snow-guards" class="dropdown-item" role="menuitem">Snow Retention</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 1: 3 cards -->
    <div class="card-grid row-3">
      <!-- Card: Roof Panels -->
      <a href="/products#roof-panels" class="card scroll-reveal" style="--delay: 0.1s">
        <div class="card-top">
          <!-- Warehouse/garage icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 640 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 488V171.3c0-26.2 15.9-49.7 40.2-59.4L308.1 4.8c7.6-3.1 16.1-3.1 23.8 0L599.8 111.9c24.3 9.7 40.2 33.3 40.2 59.4V488c0 13.3-10.7 24-24 24H568c-13.3 0-24-10.7-24-24V224c0-17.7-14.3-32-32-32H128c-17.7 0-32 14.3-32 32V488c0 13.3-10.7 24-24 24H24c-13.3 0-24-10.7-24-24zm488 24l-336 0c-13.3 0-24-10.7-24-24V224H520V488c0 13.3-10.7 24-24 24z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Roof Panels</h3>
        <p class="card-body">Custom standing seam concealed fastener and exposed fastener panels.</p>
      </a>

      <!-- Card: Wall Panels -->
      <a href="/products#wall-panels" class="card scroll-reveal" style="--delay: 0.2s">
        <div class="card-top">
          <!-- Building/grid icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 384 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M48 0C21.5 0 0 21.5 0 48V464c0 26.5 21.5 48 48 48h96V432c0-26.5 21.5-48 48-48s48 21.5 48 48v80h96c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48H48zM64 240c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H80c-8.8 0-16-7.2-16-16V240zm112-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H176c-8.8 0-16-7.2-16-16V240c0-8.8 7.2-16 16-16zm80 16c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H272c-8.8 0-16-7.2-16-16V240zM80 96h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H80c-8.8 0-16-7.2-16-16V112c0-8.8 7.2-16 16-16zm80 16c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H176c-8.8 0-16-7.2-16-16V112zM272 96h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H272c-8.8 0-16-7.2-16-16V112c0-8.8 7.2-16 16-16z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Wall Panels</h3>
        <p class="card-body">Durable metal wall panels built for commercial and residential applications.</p>
      </a>

      <!-- Card: Trims & Flashing -->
      <a href="/products#trims-flashing" class="card scroll-reveal" style="--delay: 0.3s">
        <div class="card-top">
          <!-- Ruler/trim icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M177.9 494.1c-18.7 18.7-49.1 18.7-67.9 0L17.9 401.9c-18.7-18.7-18.7-49.1 0-67.9l50.7-50.7 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48L327.3 17.9c18.7-18.7 49.1-18.7 67.9 0l92.1 92.1c18.7 18.7 18.7 49.1 0 67.9L177.9 494.1z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Trims & Flashing</h3>
        <p class="card-body">Every edge, transition, and termination point cut and bent in-house.</p>
      </a>
    </div>

    <!-- Row 2: 3 cards -->
    <div class="card-grid row-3">
      <!-- Card: Fasteners & Hardware -->
      <a href="/products#fasteners-hardware" class="card scroll-reveal" style="--delay: 0.1s">
        <div class="card-top">
          <!-- Wrench icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M352 320c88.4 0 160-71.6 160-160c0-15.3-2.2-30.1-6.2-44.2c-3.1-10.8-16.4-13.2-24.3-5.3l-76.8 76.8c-3 3-7.1 4.7-11.3 4.7H336c-8.8 0-16-7.2-16-16V117.6c0-4.2 1.7-8.3 4.7-11.3l76.8-76.8c7.9-7.9 5.4-21.2-5.3-24.3C382.1 2.2 367.3 0 352 0C263.6 0 192 71.6 192 160c0 19.1 3.4 37.5 9.5 54.5L19.9 396.1C7.2 408.8 0 426.1 0 444.1C0 481.6 30.4 512 67.9 512c18 0 35.3-7.2 48-19.9L297.5 310.5c17 6.2 35.4 9.5 54.5 9.5zM80 456c-13.3 0-24-10.7-24-24s10.7-24 24-24s24 10.7 24 24s-10.7 24-24 24z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Fasteners & Hardware</h3>
        <p class="card-body">The right fastener for every panel profile and substrate.</p>
      </a>

      <!-- Card: Sealants & Adhesives -->
      <a href="/products#sealants-adhesives" class="card scroll-reveal" style="--delay: 0.2s">
        <div class="card-top">
          <!-- Paint roller/sealant icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 64C0 28.7 28.7 0 64 0H352c35.3 0 64 28.7 64 64v64c0 35.3-28.7 64-64 64H234.7L256 224h64c17.7 0 32 14.3 32 32v32c0 17.7-14.3 32-32 32H280v144c0 26.5-21.5 48-48 48s-48-21.5-48-48V320H160c-17.7 0-32-14.3-32-32V256c0-17.7 14.3-32 32-32h64L181.3 192H64C28.7 192 0 163.3 0 128V64zM64 128H352V64H64v64z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Sealants & Adhesives</h3>
        <p class="card-body">Caulks, butyl tape, and adhesives spec'd for metal roofing systems.</p>
      </a>

      <!-- Card: Snow Retention -->
      <a href="/products#snow-guards" class="card scroll-reveal" style="--delay: 0.3s">
        <div class="card-top">
          <!-- Snowflake icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 448 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M224 0c17.7 0 32 14.3 32 32V62.1l15-15c9.4-9.4 24.6-9.4 33.9 0s9.4 24.6 0 33.9l-49 49v70.3l61.4-35.8 17.7-66.1c3.4-12.8 16.6-20.4 29.4-17s20.4 16.6 17 29.4l-5.2 19.3 23.6-13.8c15.3-8.9 34.9-3.7 43.8 11.5s3.8 34.9-11.5 43.8l-23.6 13.8 19.3 5.2c12.8 3.4 20.4 16.6 17 29.4s-16.6 20.4-29.4 17l-66.1-17.7L287.9 256l61.4 35.8 66.1-17.7c12.8-3.4 26 4.2 29.4 17s-4.2 26-17 29.4l-19.3 5.2 23.6 13.8c15.3 8.9 20.4 28.5 11.5 43.8s-28.5 20.4-43.8 11.5l-23.6-13.8 5.2 19.3c3.4 12.8-4.2 26-17 29.4s-26-4.2-29.4-17l-17.7-66.1L256 331.2v70.3l49 49c9.4 9.4 9.4 24.6 0 33.9s-24.6 9.4-33.9 0l-15-15V480c0 17.7-14.3 32-32 32s-32-14.3-32-32V449.9l-15 15c-9.4 9.4-24.6 9.4-33.9 0s-9.4-24.6 0-33.9l49-49V311.6l-61.4 35.8-17.7 66.1c-3.4 12.8-16.6 20.4-29.4 17s-20.4-16.6-17-29.4l5.2-19.3L48.2 395.6c-15.3 8.9-34.9 3.7-43.8-11.5s-3.7-34.9 11.5-43.8l23.6-13.8-19.3-5.2c-12.8-3.4-20.4-16.6-17-29.4s16.6-20.4 29.4-17l66.1 17.7L160.1 256 98.6 220.2l-66.1 17.7c-12.8 3.4-26-4.2-29.4-17s4.2-26 17-29.4l19.3-5.2L15.8 172.5c-15.3-8.9-20.4-28.5-11.5-43.8s28.5-20.4 43.8-11.5l23.6 13.8-5.2-19.3c-3.4-12.8 4.2-26 17-29.4s26 4.2 29.4 17l17.7 66.1L192 200.8V130.5l-49-49c-9.4-9.4-9.4-24.6 0-33.9s24.6-9.4 33.9 0l15 15V32c0-17.7 14.3-32 32-32z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Snow Retention</h3>
        <p class="card-body">Protect people and property from roof avalanches. Essential for mountain builds.</p>
      </a>
    </div>

    <!-- Row 3: Underlayments (featured) -->
    <div class="card-grid row-1">
      <a href="/products" class="card card--featured scroll-reveal" style="--delay: 0.1s">
        <span class="coming-soon-badge">Coming Soon</span>
        <div class="card-top">
          <!-- Shield/layer icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.7 82.8c22 9.3 38.4 31 38.3 57.2c-.5 99.2-41.3 280.7-213.6 363.2c-16.7 8-36.1 8-52.8 0C57.3 420.7 16.5 239.2 16 140c-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.8 1 251.4 0 256 0z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Underlayments</h3>
        <p class="card-body">A full range of underlayment options including self-adhered high-temp, butyl-based and asphalt-based options, and mechanically fastened synthetic. Exclusive FlashDeck partnership.</p>
      </a>
    </div>
  </div>
</section>

<style>
  .products {
    background: var(--bg);
    padding: 80px 0;
    overflow: hidden;
  }

  .products-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
  }

  /* Top Row */
  .top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    margin-left: -80px;
    margin-right: -80px;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
  }

  .section-headline {
    font-family: var(--font-heading);
    font-size: 72px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 110%;
    max-width: 642px;
  }

  .headline-accent {
    color: var(--blue-accent);
  }

  .top-right {
    flex-shrink: 0;
    text-align: left;
  }

  .explore-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 4rem;
  }

  .explore-label {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 500;
    color: var(--white-muted);
    white-space: nowrap;
  }

  /* Dropdown */
  .dropdown-wrap {
    position: relative;
  }

  .cta-blue {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--white);
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--white);
    text-transform: capitalize;
    padding: 16px 25px 16px 35px;
    height: 60px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-blue::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: var(--blue-accent);
    z-index: -1;
    transition: width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-blue:hover {
    border-color: var(--blue-accent);
    color: var(--black);
  }

  .cta-blue:hover::before {
    width: 100%;
  }

  .dropdown-chevron {
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .dropdown-wrap.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 100%;
    background: var(--bg);
    border: 1px solid rgba(232, 232, 232, 0.2);
    display: none;
    flex-direction: column;
    z-index: 10;
  }

  .dropdown-wrap.open .dropdown-menu {
    display: flex;
  }

  .dropdown-item {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    padding: 14px 24px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .dropdown-item:hover {
    background: var(--blue-primary);
    color: var(--white-full);
  }

  .dropdown-item--featured {
    color: #F5C518;
  }

  .dropdown-item--featured:hover {
    background: #F5C518;
    color: var(--black);
  }

  .top-right-sub {
    margin-top: 16px;
  }

  .accent-bar {
    width: 30px;
    height: 2px;
    background: var(--blue-primary);
    margin-bottom: 12px;
    transition: background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .top-right-subtext {
    font-family: var(--font-body);
    font-size: 20px;
    color: var(--white-muted);
    line-height: 150%;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .top-right-sub:hover .accent-bar {
    background: var(--blue-accent);
    width: 50px;
  }

  .top-right-sub:hover .top-right-subtext {
    color: var(--white-full);
  }

  /* Card Grids */
  .card-grid {
    margin-top: 20px;
  }

  .card-grid:first-of-type {
    margin-top: 60px;
  }

  .row-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-left: -80px;
    margin-right: -80px;
  }

  .row-1 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-left: -80px;
    margin-right: -80px;
  }

  /* Card Base */
  .card {
    position: relative;
    border: 1px solid var(--white);
    background: transparent;
    padding: 28px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    min-height: 250px;
    transition: background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  /* Merge scroll-reveal opacity/transform into scoped transition */
  .card.scroll-reveal {
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.1, 0.25, 1),
      background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
      border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
      box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    transition-delay: var(--delay, 0s);
  }

  .card:hover {
    background: var(--blue-accent);
    border-color: var(--blue-accent);
    transform: translateY(-6px);
    box-shadow: 0 16px 32px rgba(0, 162, 233, 0.15);
  }

  /* Featured Underlayments Card */
  .card--featured {
    border-color: #F5C518;
    background: rgba(245, 197, 24, 0.04);
  }

  .card--featured:hover {
    background: #F5C518;
    border-color: #F5C518;
    box-shadow: 0 16px 32px rgba(245, 197, 24, 0.2);
  }

  .card--featured:hover .card-title,
  .card--featured:hover .card-body,
  .card--featured:hover .card-icon,
  .card--featured:hover .card-arrow path {
    color: var(--black);
    fill: var(--black);
    stroke: var(--black);
  }

  .coming-soon-badge {
    position: absolute;
    top: 16px;
    right: 68px;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--black);
    background: #F5C518;
    padding: 6px 14px;
    z-index: 2;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .card-arrow {
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card:hover .card-arrow {
    transform: translate(4px, -4px);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-top: 40px;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-body {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
