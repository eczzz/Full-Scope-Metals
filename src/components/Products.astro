---

---

<section class="products">
  <div class="products-inner">
    <!-- Top Content -->
    <div class="top-row">
      <div class="top-left scroll-reveal">
        <p class="section-label">Products</p>
        <h2 class="section-headline">Everything Your Metal Roof Needs.</h2>
      </div>

      <div class="top-right scroll-reveal" style="--delay: 0.15s">
        <div class="top-right-sub">
          <div class="accent-bar"></div>
          <p class="top-right-subtext">Manufactured and sourced<br />from our Colorado shop.</p>
        </div>
        <div class="explore-row">
          <p class="explore-label">Explore Products:</p>
          <a href="/products/roof-panels" class="cta-blue">
            <span>Roof Panels</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Row 1: 3 cards -->
    <div class="card-grid row-3">
      <!-- Card: Roof Panels -->
      <a href="/products/roof-panels" class="card scroll-reveal" style="--delay: 0.1s">
        <div class="card-top">
          <!-- Warehouse/garage icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 640 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 488V171.3c0-26.2 15.9-49.7 40.2-59.4L308.1 4.8c7.6-3.1 16.1-3.1 23.8 0L599.8 111.9c24.3 9.7 40.2 33.3 40.2 59.4V488c0 13.3-10.7 24-24 24H568c-13.3 0-24-10.7-24-24V224c0-17.7-14.3-32-32-32H128c-17.7 0-32 14.3-32 32V488c0 13.3-10.7 24-24 24H24c-13.3 0-24-10.7-24-24zm488 24l-336 0c-13.3 0-24-10.7-24-24V224H520V488c0 13.3-10.7 24-24 24z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Roof Panels</h3>
        <p class="card-body">Custom standing seam and metal roof panels fabricated to your exact spec.</p>
      </a>

      <!-- Card: Wall Panels -->
      <a href="/products/wall-panels" class="card scroll-reveal" style="--delay: 0.2s">
        <div class="card-top">
          <!-- Building/grid icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 384 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M48 0C21.5 0 0 21.5 0 48V464c0 26.5 21.5 48 48 48h96V432c0-26.5 21.5-48 48-48s48 21.5 48 48v80h96c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48H48zM64 240c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H80c-8.8 0-16-7.2-16-16V240zm112-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H176c-8.8 0-16-7.2-16-16V240c0-8.8 7.2-16 16-16zm80 16c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H272c-8.8 0-16-7.2-16-16V240zM80 96h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H80c-8.8 0-16-7.2-16-16V112c0-8.8 7.2-16 16-16zm80 16c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H176c-8.8 0-16-7.2-16-16V112zM272 96h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H272c-8.8 0-16-7.2-16-16V112c0-8.8 7.2-16 16-16z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Wall Panels</h3>
        <p class="card-body">Durable metal wall panels built for commercial and residential applications.</p>
      </a>

      <!-- Card: Trims & Flashing -->
      <a href="/products/trims-flashing" class="card scroll-reveal" style="--delay: 0.3s">
        <div class="card-top">
          <!-- Ruler/trim icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M177.9 494.1c-18.7 18.7-49.1 18.7-67.9 0L17.9 401.9c-18.7-18.7-18.7-49.1 0-67.9l50.7-50.7 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48L327.3 17.9c18.7-18.7 49.1-18.7 67.9 0l92.1 92.1c18.7 18.7 18.7 49.1 0 67.9L177.9 494.1z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Trims & Flashing</h3>
        <p class="card-body">Every edge, transition, and termination point cut and bent in-house.</p>
      </a>
    </div>

    <!-- Row 2: 3 cards -->
    <div class="card-grid row-3">
      <!-- Card: Fasteners & Hardware -->
      <a href="/products/fasteners-hardware" class="card scroll-reveal" style="--delay: 0.1s">
        <div class="card-top">
          <!-- Wrench icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M352 320c88.4 0 160-71.6 160-160c0-15.3-2.2-30.1-6.2-44.2c-3.1-10.8-16.4-13.2-24.3-5.3l-76.8 76.8c-3 3-7.1 4.7-11.3 4.7H336c-8.8 0-16-7.2-16-16V117.6c0-4.2 1.7-8.3 4.7-11.3l76.8-76.8c7.9-7.9 5.4-21.2-5.3-24.3C382.1 2.2 367.3 0 352 0C263.6 0 192 71.6 192 160c0 19.1 3.4 37.5 9.5 54.5L19.9 396.1C7.2 408.8 0 426.1 0 444.1C0 481.6 30.4 512 67.9 512c18 0 35.3-7.2 48-19.9L297.5 310.5c17 6.2 35.4 9.5 54.5 9.5zM80 456c-13.3 0-24-10.7-24-24s10.7-24 24-24s24 10.7 24 24s-10.7 24-24 24z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Fasteners & Hardware</h3>
        <p class="card-body">The right fastener for every panel profile and substrate.</p>
      </a>

      <!-- Card: Sealants & Adhesives -->
      <a href="/products/sealants-adhesives" class="card scroll-reveal" style="--delay: 0.2s">
        <div class="card-top">
          <!-- Paint roller/sealant icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 64C0 28.7 28.7 0 64 0H352c35.3 0 64 28.7 64 64v64c0 35.3-28.7 64-64 64H234.7L256 224h64c17.7 0 32 14.3 32 32v32c0 17.7-14.3 32-32 32H280v144c0 26.5-21.5 48-48 48s-48-21.5-48-48V320H160c-17.7 0-32-14.3-32-32V256c0-17.7 14.3-32 32-32h64L181.3 192H64C28.7 192 0 163.3 0 128V64zM64 128H352V64H64v64z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Sealants & Adhesives</h3>
        <p class="card-body">Caulks, butyl tape, and adhesives spec'd for metal roofing systems.</p>
      </a>

      <!-- Card: Underlayments & Accessories -->
      <a href="/products/underlayments-accessories" class="card scroll-reveal" style="--delay: 0.3s">
        <div class="card-top">
          <!-- Layer group/stack icon -->
          <svg class="card-icon" width="32" height="32" viewBox="0 0 576 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M264.5 5.2c14.9-6.9 32.1-6.9 47 0l218.6 101c8.5 3.9 13.9 12.4 13.9 21.8s-5.4 17.9-13.9 21.8l-218.6 101c-14.9 6.9-32.1 6.9-47 0L45.9 149.8C37.4 145.8 32 137.3 32 128s5.4-17.9 13.9-21.8L264.5 5.2zM476.9 209.6l53.2 24.6c8.5 3.9 13.9 12.4 13.9 21.8s-5.4 17.9-13.9 21.8l-218.6 101c-14.9 6.9-32.1 6.9-47 0L45.9 277.8C37.4 273.8 32 265.3 32 256s5.4-17.9 13.9-21.8l53.2-24.6 152 70.2c23.4 10.8 50.4 10.8 73.8 0l152-70.2zm-152 198.2l152-70.2 53.2 24.6c8.5 3.9 13.9 12.4 13.9 21.8s-5.4 17.9-13.9 21.8l-218.6 101c-14.9 6.9-32.1 6.9-47 0L45.9 405.8C37.4 401.8 32 393.3 32 384s5.4-17.9 13.9-21.8l53.2-24.6 152 70.2c23.4 10.8 50.4 10.8 73.8 0z"/>
          </svg>
          <svg class="card-arrow" width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 27L27 11M27 11H13M27 11V25" stroke="#E8E8E8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card-title">Underlayments & Accessories</h3>
        <p class="card-body">Roof boots, pipe jacks, underlayments; everything else the job needs.</p>
      </a>
    </div>
  </div>
</section>

<style>
  .products {
    background: var(--bg);
    padding: 80px 0;
    overflow: hidden;
  }

  .products-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
  }

  /* Top Row */
  .top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    margin-left: -80px;
    margin-right: -80px;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
  }

  .section-headline {
    font-family: var(--font-heading);
    font-size: 72px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 110%;
    max-width: 642px;
  }

  .top-right {
    flex-shrink: 0;
    text-align: left;
  }

  .explore-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 16px;
  }

  .explore-label {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 500;
    color: var(--white-muted);
    white-space: nowrap;
  }

  .cta-blue {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--white);
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--white);
    text-transform: capitalize;
    padding: 16px 25px 16px 35px;
    height: 60px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-blue::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: var(--blue-accent);
    z-index: -1;
    transition: width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-blue:hover {
    border-color: var(--blue-accent);
    color: var(--black);
  }

  .cta-blue:hover::before {
    width: 100%;
  }

  .top-right-sub {
    margin-top: 16px;
  }

  .accent-bar {
    width: 30px;
    height: 2px;
    background: var(--blue-primary);
    margin-bottom: 12px;
    transition: background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .top-right-subtext {
    font-family: var(--font-body);
    font-size: 20px;
    color: var(--white-muted);
    line-height: 150%;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .top-right-sub:hover .accent-bar {
    background: var(--blue-accent);
    width: 50px;
  }

  .top-right-sub:hover .top-right-subtext {
    color: var(--white-full);
  }

  /* Card Grids */
  .card-grid {
    margin-top: 20px;
  }

  .card-grid:first-of-type {
    margin-top: 60px;
  }

  .row-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-left: -80px;
    margin-right: -80px;
  }

  /* Card Base */
  .card {
    position: relative;
    border: 1px solid var(--white);
    background: transparent;
    padding: 28px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    min-height: 250px;
    transition: background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card:hover {
    background: var(--blue-accent);
    border-color: var(--blue-accent);
    transform: translateY(-6px);
    box-shadow: 0 16px 32px rgba(0, 162, 233, 0.15);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .card-arrow {
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card:hover .card-arrow {
    transform: translate(4px, -4px);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-top: 40px;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-body {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 150%;
    margin-top: 12px;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-icon {
    flex-shrink: 0;
    transition: fill 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card-arrow path {
    transition: stroke 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .card:hover .card-title {
    color: var(--black);
  }

  .card:hover .card-body {
    color: var(--black);
  }

  .card:hover .card-icon {
    fill: var(--black);
  }

  .card:hover .card-arrow path {
    stroke: var(--black);
  }

  /* 1200px */
  @media (max-width: 1200px) {
    .products-inner {
      padding: 0 60px;
    }

    .section-headline {
      font-size: 60px;
    }

    .top-row {
      margin-left: 0;
      margin-right: 0;
    }

    .row-3 {
      margin-left: 0;
      margin-right: 0;
    }
  }

  /* 1024px */
  @media (max-width: 1024px) {
    .products {
      padding: 64px 0;
    }

    .products-inner {
      padding: 0 40px;
    }

    .section-headline {
      font-size: 48px;
    }

    .top-row {
      flex-direction: column;
      gap: 32px;
    }

    .row-3 {
      grid-template-columns: 1fr;
    }

    .card {
      min-height: 220px;
      padding: 24px;
    }

    .card-title {
      font-size: 24px;
      margin-top: 28px;
    }

    .card-body {
      font-size: 18px;
    }
  }

  /* 768px */
  @media (max-width: 768px) {
    .products {
      padding: 48px 0;
    }

    .products-inner {
      padding: 0 24px;
    }

    .section-label {
      font-size: 18px;
    }

    .section-headline {
      font-size: 36px;
    }

    .row-3 {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .card {
      min-height: auto;
    }

    .card-title {
      font-size: 22px;
      margin-top: 24px;
    }

    .card-body {
      font-size: 16px;
    }

    .explore-label,
    .top-right-subtext {
      font-size: 16px;
    }

    .cta-blue {
      font-size: 16px;
      padding: 14px 20px 14px 28px;
      height: 52px;
    }
  }

  /* 480px */
  @media (max-width: 480px) {
    .products {
      padding: 40px 0;
    }

    .products-inner {
      padding: 0 16px;
    }

    .section-label {
      font-size: 16px;
      margin-bottom: 12px;
    }

    .section-headline {
      font-size: 28px;
    }

    .card-grid:first-of-type {
      margin-top: 40px;
    }

    .card {
      padding: 20px;
    }

    .card-title {
      font-size: 20px;
      margin-top: 20px;
    }

    .card-body {
      font-size: 14px;
    }

    .explore-label,
    .top-right-subtext {
      font-size: 14px;
    }

    .cta-blue {
      font-size: 14px;
      padding: 12px 16px 12px 24px;
      height: 48px;
    }
  }
</style>
