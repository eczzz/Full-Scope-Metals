---

---

<section class="product-categories">
  <div class="categories-inner">

    <!-- Section Header -->
    <div class="categories-header scroll-reveal">
      <p class="section-label">What We Build</p>
      <h2 class="section-headline">Six Categories.<br /><span class="headline-accent">Zero Shortcuts.</span></h2>
    </div>

    <!-- ===== 01 — Roof Panels (Featured Left) ===== -->
    <article id="roof-panels" class="category category--featured scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-img-wrap">
          <img src="/full-scope-products-roof-panels.webp" alt="Roof Panels" width="1024" height="1024" loading="lazy" />
        </div>
        <span class="category-number">01</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Roof Panels</h3>
        <p class="category-desc">Custom standing seam and metal roof panels fabricated to your exact spec. Every panel rolls off our line measured, cut, and formed for your job.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Standing seam profiles: snap-lock & mechanical lock</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Exposed fastener panels</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Custom widths and lengths</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">24–26 gauge steel and aluminum options</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Kynar/PVDF and SMP finish systems</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Custom color matching available</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 02 — Wall Panels (Featured Right) ===== -->
    <article id="wall-panels" class="category category--featured category--reverse scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-img-wrap">
          <img src="/full-scope-products-wall-panels.webp" alt="Wall Panels" width="1024" height="1024" loading="lazy" />
        </div>
        <span class="category-number">02</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Wall Panels</h3>
        <p class="category-desc">Durable metal wall panels built for commercial and residential applications. Same precision, same shop. Matched to your roof system or standing on their own.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Flush-wall profiles</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Corrugated panels</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Board-and-batten style</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Concealed fastener systems</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Multiple gauge options</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Matching color systems with roof panels</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 03 — Trims & Flashing (Featured Left) ===== -->
    <article id="trims-flashing" class="category category--featured scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-img-wrap">
          <img src="/full-scope-products-trims-and-flashings.webp" alt="Trims & Flashing" width="1024" height="1024" loading="lazy" />
        </div>
        <span class="category-number">03</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Trims & Flashing</h3>
        <p class="category-desc">Every edge, transition, and termination point cut and bent in-house. If you can draw it, we can break it. Custom profiles are our bread and butter.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Ridge caps & drip edges</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Valley flashing</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Headwall and sidewall flashing</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Custom profiles to your drawings</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">J-channel & Z-flashing</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Specialty bends</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 04 — Fasteners & Hardware (Featured Right) ===== -->
    <article id="fasteners-hardware" class="category category--featured category--reverse scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-img-wrap">
          <img src="/full-scope-products-fasteners-and-adhesives.webp" alt="Fasteners & Hardware" width="1024" height="1024" loading="lazy" />
        </div>
        <span class="category-number">04</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Fasteners & Hardware</h3>
        <p class="category-desc">The right fastener for every panel profile and substrate. We stock what works and can source anything we don't carry.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Pancake and hex-head screws</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Stitch screws for panel-to-panel</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Color-matched painted heads</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">EPDM washers for weathertight seal</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Bulk and job-pack quantities</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 05 — Sealants & Adhesives (Featured Left) ===== -->
    <article id="sealants-adhesives" class="category category--featured scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-img-wrap">
          <img src="/full-scope-products-sealants-and-adhesives.webp" alt="Sealants & Adhesives" width="1024" height="1024" loading="lazy" />
        </div>
        <span class="category-number">05</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Sealants & Adhesives</h3>
        <p class="category-desc">Weatherproofing solutions matched to your panel system. We carry what the manufacturers recommend, and we know which ones actually hold up in mountain winters.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Butyl tape for standing seam</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Tube sealants for exposed fastener</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Closure strips: inside and outside</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Compatible with all major paint systems</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">UV-stable formulas</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 06 — Snow Guards (Featured Right) ===== -->
    <article id="snow-guards" class="category category--featured category--reverse scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-img-wrap">
          <img src="/full-scope-products-snow-guards.webp" alt="Snow Guards" width="1024" height="1024" loading="lazy" />
        </div>
        <span class="category-number">06</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Snow Guards</h3>
        <p class="category-desc">Protect people and property from roof avalanches. In the Colorado high country, this isn't optional. It's part of the system.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Pad-style guards for standing seam</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Bar-style continuous systems</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Color-matched to panel finish</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Calculated placement patterns based on roof pitch & snow load</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Compatible with all panel profiles we fabricate</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

  </div>
</section>

<style>
  /* ===========================
     Section Container
     =========================== */
  .product-categories {
    background: var(--bg);
    padding: 100px 0 80px;
    overflow: hidden;
  }

  .categories-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
  }

  /* ===========================
     Section Header
     =========================== */
  .categories-header {
    margin-bottom: 80px;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
  }

  .section-headline {
    font-family: var(--font-heading);
    font-size: 56px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 115%;
  }

  .headline-accent {
    color: var(--blue-accent);
  }

  /* ===========================
     Category Block — Shared
     =========================== */
  .category {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 60px;
    align-items: start;
    padding: 60px 0;
  }

  /* BUG FIX: merge opacity/transform into scoped transition for scroll-reveal elements */
  .category.scroll-reveal {
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);
    transition-delay: var(--delay, 0s);
  }

  /* ===========================
     Reverse Layout (even categories)
     =========================== */
  .category--reverse {
    grid-template-columns: 1fr 280px;
  }

  .category--reverse .category-visual {
    order: 2;
  }

  .category--reverse .category-content {
    order: 1;
  }

  /* ===========================
     Visual Column (Image + Number)
     =========================== */
  .category-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: sticky;
    top: 120px;
  }

  .category-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid rgba(232, 232, 232, 0.12);
    position: relative;
    transition: border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category-img-wrap::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--blue-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
    z-index: 1;
  }

  .category:hover .category-img-wrap {
    border-color: rgba(0, 162, 233, 0.3);
  }

  .category:hover .category-img-wrap::before {
    transform: scaleX(1);
  }

  .category-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category:hover .category-img-wrap img {
    transform: scale(1.05);
  }

  .category-number {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--blue-primary);
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category:hover .category-number {
    color: var(--blue-accent);
  }

  /* ===========================
     Content Column
     =========================== */
  .category-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 115%;
    margin-bottom: 16px;
  }

  .category-desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 170%;
    max-width: 680px;
    margin-bottom: 36px;
  }

  /* ===========================
     Spec Grid
     =========================== */
  .spec-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 36px;
    border-top: 1px solid rgba(232, 232, 232, 0.08);
  }

  .spec-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 20px 16px 0;
    border-bottom: 1px solid rgba(232, 232, 232, 0.08);
    transition: background 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .spec-item:hover {
    background: rgba(36, 93, 167, 0.06);
  }

  .spec-marker {
    width: 8px;
    height: 8px;
    min-width: 8px;
    background: var(--blue-primary);
    margin-top: 7px;
    transition: background 0.3s cubic-bezier(0.25, 0.1, 0.25, 1), transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .spec-item:hover .spec-marker {
    background: var(--blue-accent);
    transform: scale(1.25);
  }

  .spec-text {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--white);
    line-height: 155%;
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .spec-item:hover .spec-text {
    color: var(--white-full);
  }

  /* ===========================
     Category CTA
     =========================== */
  .category-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--white);
    border: 1px solid rgba(232, 232, 232, 0.25);
    background: transparent;
    padding: 14px 24px;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: var(--blue-accent);
    z-index: -1;
    transition: width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category-cta:hover {
    color: var(--black);
    border-color: var(--blue-accent);
  }

  .category-cta:hover::before {
    width: 100%;
  }

  .category-cta svg {
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category-cta:hover svg {
    transform: translate(3px, -3px);
  }

  /* ===========================
     Divider
     =========================== */
  .category-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(36, 93, 167, 0.4) 20%,
      var(--blue-primary) 50%,
      rgba(36, 93, 167, 0.4) 80%,
      transparent 100%
    );
  }

  /* BUG FIX: merge opacity/transform for scroll-reveal dividers */
  .category-divider.scroll-reveal {
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);
    transition-delay: var(--delay, 0s);
  }

  /* ===========================
     Responsive — 1200px
     =========================== */
  @media (max-width: 1200px) {
    .categories-inner {
      padding: 0 80px;
    }

    .section-headline {
      font-size: 48px;
    }

    .category {
      grid-template-columns: 220px 1fr;
      gap: 48px;
    }

    .category--reverse {
      grid-template-columns: 1fr 220px;
    }

    .category-title {
      font-size: 36px;
    }
  }

  /* ===========================
     Responsive — 1024px
     =========================== */
  @media (max-width: 1024px) {
    .product-categories {
      padding: 80px 0 64px;
    }

    .categories-inner {
      padding: 0 48px;
    }

    .categories-header {
      margin-bottom: 60px;
    }

    .section-headline {
      font-size: 40px;
    }

    .category {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 48px 0;
    }

    .category--reverse {
      grid-template-columns: 1fr;
    }

    .category--reverse .category-visual {
      order: 0;
    }

    .category--reverse .category-content {
      order: 0;
    }

    /* Unstick + horizontal layout for visual column */
    .category-visual {
      flex-direction: row;
      align-items: center;
      gap: 16px;
      position: static;
    }

    .category-img-wrap {
      width: 120px;
      aspect-ratio: 1 / 1;
      flex-shrink: 0;
    }

    .category-number {
      font-size: 32px;
      color: var(--blue-accent);
      letter-spacing: 0.04em;
      opacity: 0.9;
    }

    .category-title {
      font-size: 32px;
    }

    .category-desc {
      font-size: 16px;
      max-width: 100%;
    }

    .spec-grid {
      grid-template-columns: 1fr;
    }

    /* Stronger dividers for category separation */
    .category-divider {
      height: 2px;
    }
  }

  /* ===========================
     Responsive — 768px
     =========================== */
  @media (max-width: 768px) {
    .product-categories {
      padding: 64px 0 48px;
    }

    .categories-inner {
      padding: 0 24px;
    }

    .categories-header {
      margin-bottom: 48px;
    }

    .section-headline {
      font-size: 32px;
    }

    .category {
      padding: 36px 0;
      gap: 20px;
      border-left: 3px solid var(--blue-primary);
      padding-left: 20px;
    }

    .category-visual {
      gap: 14px;
    }

    .category-img-wrap {
      width: 100px;
      border-color: rgba(0, 162, 233, 0.2);
    }

    /* Touch: always show accent bar */
    .category-img-wrap::before {
      transform: scaleX(1);
    }

    .category-number {
      font-size: 28px;
    }

    .category-title {
      font-size: 26px;
    }

    .category-desc {
      font-size: 15px;
      margin-bottom: 24px;
      line-height: 160%;
    }

    /* Spec grid: tight, scannable rows for on-site checking */
    .spec-item {
      padding: 12px 0;
      gap: 12px;
    }

    .spec-marker {
      margin-top: 6px;
    }

    .spec-text {
      font-size: 14px;
      line-height: 150%;
      color: var(--white-full);
    }

    .spec-grid {
      margin-bottom: 28px;
    }

    /* CTA: filled blue on mobile — visible in bright sun, big tap target */
    .category-cta {
      width: 100%;
      justify-content: center;
      padding: 16px 24px;
      background: var(--blue-accent);
      color: var(--black);
      border-color: var(--blue-accent);
      font-weight: 500;
    }

    .category-cta::before {
      display: none;
    }

    .category-cta:hover {
      background: var(--blue-primary);
      border-color: var(--blue-primary);
      color: var(--white-full);
    }

    /* Dividers: more visible separation between 6 categories */
    .category-divider {
      height: 2px;
      margin: 4px 0;
      background: linear-gradient(
        90deg,
        var(--blue-primary) 0%,
        rgba(36, 93, 167, 0.5) 60%,
        transparent 100%
