---

---

<section class="product-categories">
  <div class="categories-inner">

    <!-- Section Header -->
    <div class="categories-header scroll-reveal">
      <p class="section-label">What We Build</p>
      <h2 class="section-headline">Six Categories.<br /><span class="headline-accent">Zero Shortcuts.</span></h2>
    </div>

    <!-- ===== 01 — Roof Panels (Featured Left) ===== -->
    <article id="roof-panels" class="category category--featured scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-icon-wrap">
          <svg class="category-icon" width="48" height="48" viewBox="0 0 640 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 488V171.3c0-26.2 15.9-49.7 40.2-59.4L308.1 4.8c7.6-3.1 16.1-3.1 23.8 0L599.8 111.9c24.3 9.7 40.2 33.3 40.2 59.4V488c0 13.3-10.7 24-24 24H568c-13.3 0-24-10.7-24-24V224c0-17.7-14.3-32-32-32H128c-17.7 0-32 14.3-32 32V488c0 13.3-10.7 24-24 24H24c-13.3 0-24-10.7-24-24zm488 24l-336 0c-13.3 0-24-10.7-24-24V224H520V488c0 13.3-10.7 24-24 24z"/>
          </svg>
        </div>
        <span class="category-number">01</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Roof Panels</h3>
        <p class="category-desc">Custom standing seam and metal roof panels fabricated to your exact spec. Every panel rolls off our line in Kremmling — measured, cut, and formed for your job.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Standing seam profiles — snap-lock & mechanical lock</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Exposed fastener panels</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Custom widths and lengths</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">24–26 gauge steel and aluminum options</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Kynar/PVDF and SMP finish systems</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Custom color matching available</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 02 — Wall Panels (Featured Right) ===== -->
    <article id="wall-panels" class="category category--featured category--reverse scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-icon-wrap">
          <svg class="category-icon" width="48" height="48" viewBox="0 0 384 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M48 0C21.5 0 0 21.5 0 48V464c0 26.5 21.5 48 48 48h96V432c0-26.5 21.5-48 48-48s48 21.5 48 48v80h96c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48H48zM64 240c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H80c-8.8 0-16-7.2-16-16V240zm112-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H176c-8.8 0-16-7.2-16-16V240c0-8.8 7.2-16 16-16zm80 16c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H272c-8.8 0-16-7.2-16-16V240zM80 96h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H80c-8.8 0-16-7.2-16-16V112c0-8.8 7.2-16 16-16zm80 16c0-8.8 7.2-16 16-16h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H176c-8.8 0-16-7.2-16-16V112zM272 96h32c8.8 0 16 7.2 16 16v32c0 8.8-7.2 16-16 16H272c-8.8 0-16-7.2-16-16V112c0-8.8 7.2-16 16-16z"/>
          </svg>
        </div>
        <span class="category-number">02</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Wall Panels</h3>
        <p class="category-desc">Durable metal wall panels built for commercial and residential applications. Same precision, same shop — matched to your roof system or standing on their own.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Flush-wall profiles</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Corrugated panels</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Board-and-batten style</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Concealed fastener systems</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Multiple gauge options</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Matching color systems with roof panels</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 03 — Trims & Flashing (Featured Left) ===== -->
    <article id="trims-flashing" class="category category--featured scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-icon-wrap">
          <svg class="category-icon" width="48" height="48" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M177.9 494.1c-18.7 18.7-49.1 18.7-67.9 0L17.9 401.9c-18.7-18.7-18.7-49.1 0-67.9l50.7-50.7 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48L327.3 17.9c18.7-18.7 49.1-18.7 67.9 0l92.1 92.1c18.7 18.7 18.7 49.1 0 67.9L177.9 494.1z"/>
          </svg>
        </div>
        <span class="category-number">03</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Trims & Flashing</h3>
        <p class="category-desc">Every edge, transition, and termination point cut and bent in-house. If you can draw it, we can break it — custom profiles are our bread and butter.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Ridge caps & drip edges</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Valley flashing</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Headwall and sidewall flashing</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Custom profiles to your drawings</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">J-channel & Z-flashing</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Specialty bends</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 04 — Fasteners & Hardware (Featured Right) ===== -->
    <article id="fasteners-hardware" class="category category--featured category--reverse scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-icon-wrap">
          <svg class="category-icon" width="48" height="48" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M352 320c88.4 0 160-71.6 160-160c0-15.3-2.2-30.1-6.2-44.2c-3.1-10.8-16.4-13.2-24.3-5.3l-76.8 76.8c-3 3-7.1 4.7-11.3 4.7H336c-8.8 0-16-7.2-16-16V117.6c0-4.2 1.7-8.3 4.7-11.3l76.8-76.8c7.9-7.9 5.4-21.2-5.3-24.3C382.1 2.2 367.3 0 352 0C263.6 0 192 71.6 192 160c0 19.1 3.4 37.5 9.5 54.5L19.9 396.1C7.2 408.8 0 426.1 0 444.1C0 481.6 30.4 512 67.9 512c18 0 35.3-7.2 48-19.9L297.5 310.5c17 6.2 35.4 9.5 54.5 9.5zM80 456c-13.3 0-24-10.7-24-24s10.7-24 24-24s24 10.7 24 24s-10.7 24-24 24z"/>
          </svg>
        </div>
        <span class="category-number">04</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Fasteners & Hardware</h3>
        <p class="category-desc">The right fastener for every panel profile and substrate. We stock what works and can source anything we don't carry.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Pancake and hex-head screws</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Stitch screws for panel-to-panel</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Color-matched painted heads</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">EPDM washers for weathertight seal</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Bulk and job-pack quantities</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 05 — Sealants & Adhesives (Featured Left) ===== -->
    <article id="sealants-adhesives" class="category category--featured scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-icon-wrap">
          <svg class="category-icon" width="48" height="48" viewBox="0 0 512 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 64C0 28.7 28.7 0 64 0H352c35.3 0 64 28.7 64 64v64c0 35.3-28.7 64-64 64H234.7L256 224h64c17.7 0 32 14.3 32 32v32c0 17.7-14.3 32-32 32H280v144c0 26.5-21.5 48-48 48s-48-21.5-48-48V320H160c-17.7 0-32-14.3-32-32V256c0-17.7 14.3-32 32-32h64L181.3 192H64C28.7 192 0 163.3 0 128V64zM64 128H352V64H64v64z"/>
          </svg>
        </div>
        <span class="category-number">05</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Sealants & Adhesives</h3>
        <p class="category-desc">Weatherproofing solutions matched to your panel system. We carry what the manufacturers recommend — and we know which ones actually hold up in Colorado winters.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Butyl tape for standing seam</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Tube sealants for exposed fastener</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Closure strips — inside and outside</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Compatible with all major paint systems</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">UV-stable formulas</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

    <!-- Divider -->
    <div class="category-divider scroll-reveal" style="--delay: 0s"></div>

    <!-- ===== 06 — Snow Guards (Featured Right) ===== -->
    <article id="snow-guards" class="category category--featured category--reverse scroll-reveal" style="--delay: 0.1s">
      <div class="category-visual">
        <div class="category-icon-wrap">
          <!-- Snowflake/shield icon for snow guards -->
          <svg class="category-icon" width="48" height="48" viewBox="0 0 448 512" fill="#FFFFFF" xmlns="http://www.w3.org/2000/svg">
            <path d="M224 0c17.7 0 32 14.3 32 32V62.1l15-15c9.4-9.4 24.6-9.4 33.9 0s9.4 24.6 0 33.9l-49 49v70.3l61.4-35.8 17.7-66.1c3.4-12.8 16.6-20.4 29.4-17s20.4 16.6 17 29.4l-5.2 19.3 23.6-13.8c15.3-8.9 34.9-3.7 43.8 11.5s3.8 34.9-11.5 43.8l-23.6 13.8 19.3 5.2c12.8 3.4 20.4 16.6 17 29.4s-16.6 20.4-29.4 17l-66.1-17.7L287.9 256l61.4 35.8 66.1-17.7c12.8-3.4 26 4.2 29.4 17s-4.2 26-17 29.4l-19.3 5.2 23.6 13.8c15.3 8.9 20.4 28.5 11.5 43.8s-28.5 20.4-43.8 11.5l-23.6-13.8 5.2 19.3c3.4 12.8-4.2 26-17 29.4s-26-4.2-29.4-17l-17.7-66.1L256 331.2v70.3l49 49c9.4 9.4 9.4 24.6 0 33.9s-24.6 9.4-33.9 0l-15-15V480c0 17.7-14.3 32-32 32s-32-14.3-32-32V449.9l-15 15c-9.4 9.4-24.6 9.4-33.9 0s-9.4-24.6 0-33.9l49-49V311.6l-61.4 35.8-17.7 66.1c-3.4 12.8-16.6 20.4-29.4 17s-20.4-16.6-17-29.4l5.2-19.3L48.2 395.6c-15.3 8.9-34.9 3.7-43.8-11.5s-3.7-34.9 11.5-43.8l23.6-13.8-19.3-5.2c-12.8-3.4-20.4-16.6-17-29.4s16.6-20.4 29.4-17l66.1 17.7L160.1 256 98.6 220.2l-66.1 17.7c-12.8 3.4-26-4.2-29.4-17s4.2-26 17-29.4l19.3-5.2L15.8 172.5c-15.3-8.9-20.4-28.5-11.5-43.8s28.5-20.4 43.8-11.5l23.6 13.8-5.2-19.3c-3.4-12.8 4.2-26 17-29.4s26 4.2 29.4 17l17.7 66.1L192 200.8V130.5l-49-49c-9.4-9.4-9.4-24.6 0-33.9s24.6-9.4 33.9 0l15 15V32c0-17.7 14.3-32 32-32z"/>
          </svg>
        </div>
        <span class="category-number">06</span>
      </div>

      <div class="category-content">
        <h3 class="category-title">Snow Guards</h3>
        <p class="category-desc">Protect people and property from roof avalanches. In the Colorado high country, this isn't optional — it's part of the system.</p>

        <div class="spec-grid">
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Pad-style guards for standing seam</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Bar-style continuous systems</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Color-matched to panel finish</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Calculated placement patterns based on roof pitch & snow load</span>
          </div>
          <div class="spec-item">
            <span class="spec-marker"></span>
            <span class="spec-text">Compatible with all panel profiles we fabricate</span>
          </div>
        </div>

        <a href="/contact" class="category-cta">
          <span>Request a Quote</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M7 17L17 7M17 7H9M17 7V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </article>

  </div>
</section>

<style>
  /* ===========================
     Section Container
     =========================== */
  .product-categories {
    background: var(--bg);
    padding: 100px 0 80px;
    overflow: hidden;
  }

  .categories-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
  }

  /* ===========================
     Section Header
     =========================== */
  .categories-header {
    margin-bottom: 80px;
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blue-accent);
    margin-bottom: 16px;
  }

  .section-headline {
    font-family: var(--font-heading);
    font-size: 56px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 115%;
  }

  .headline-accent {
    color: var(--blue-accent);
  }

  /* ===========================
     Category Block — Shared
     =========================== */
  .category {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 60px;
    align-items: start;
    padding: 60px 0;
  }

  /* BUG FIX: merge opacity/transform into scoped transition for scroll-reveal elements */
  .category.scroll-reveal {
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);
    transition-delay: var(--delay, 0s);
  }

  /* ===========================
     Reverse Layout (even categories)
     =========================== */
  .category--reverse {
    grid-template-columns: 1fr 200px;
    direction: rtl;
  }

  .category--reverse > * {
    direction: ltr;
  }

  /* ===========================
     Visual Column (Icon + Number)
     =========================== */
  .category-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    position: sticky;
    top: 120px;
  }

  .category-icon-wrap {
    width: 120px;
    height: 120px;
    border: 1px solid rgba(232, 232, 232, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category-icon-wrap::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--blue-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category:hover .category-icon-wrap {
    border-color: rgba(0, 162, 233, 0.3);
    background: rgba(36, 93, 167, 0.06);
  }

  .category:hover .category-icon-wrap::before {
    transform: scaleX(1);
  }

  .category-icon {
    transition: fill 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category:hover .category-icon {
    fill: var(--blue-accent);
  }

  .category-number {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--blue-primary);
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .category:hover .category-number {
    color: var(--blue-accent);
  }

  /* ===========================
     Content Column
     =========================== */
  .category-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 115%;
    margin-bottom: 16px;
  }

  .category-desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 170%;
    max-width: 680px;
    margin-bottom: 36px;
  }

  /* ===========================
     Spec Grid
     =========================== */
  .spec-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 36px;
    border-top: 1px solid rgba(232, 232, 232, 0.08);
  }

  .spec-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 20px 16px 0;
    border-bottom: 1px solid rgba(232, 232, 232, 0.08);
