---

<section class="products-cta">
  <div class="cta-inner">

    <!-- Top rule -->
    <div class="cta-rule scroll-reveal"></div>

    <!-- Content -->
    <div class="cta-content scroll-reveal" style="--delay: 0.1s">
      <h2 class="cta-headline">Ready to Order?<br />Let's Talk.</h2>
      <p class="cta-subtext">Tell us what you need — panels, trims, accessories, or a full roof package. We'll get you a quote and a timeline.</p>

      <div class="cta-actions">
        <a href="/contact" class="cta-btn-primary">
          <span class="cta-btn-text">Get a Quote</span>
          <svg class="cta-btn-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="tel:9702812982" class="cta-phone">
          <svg class="cta-phone-icon" width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2"/>
          </svg>
          <span class="cta-phone-label">Call Now</span>
          <span class="cta-phone-number">(970) 281-2982</span>
        </a>
      </div>
    </div>

    <!-- Tagline -->
    <div class="cta-tagline scroll-reveal" style="--delay: 0.2s">
      <span class="tagline-text">Full Scope Metals — Kremmling, Colorado</span>
    </div>

  </div>
</section>

<style>
  /* ===========================
     Section
     =========================== */
  .products-cta {
    position: relative;
    background: linear-gradient(160deg, #1a3a6b 0%, var(--blue-primary) 40%, #1d4a8a 100%);
    padding: 120px 0 100px;
    overflow: hidden;
  }

  /* Subtle noise texture overlay */
  .products-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(0, 162, 233, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 30%, rgba(255, 255, 255, 0.04) 0%, transparent 50%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
    text-align: center;
  }

  /* ===========================
     Top Rule
     =========================== */
  .cta-rule {
    width: 60px;
    height: 3px;
    background: rgba(255, 255, 255, 0.4);
    margin: 0 auto 64px;
  }

  /* ===========================
     Content
     =========================== */
  .cta-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-headline {
    font-family: var(--font-heading);
    font-size: 64px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 110%;
    margin-bottom: 24px;
  }

  .cta-subtext {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.8);
    line-height: 170%;
    max-width: 560px;
    margin: 0 auto 48px;
  }

  /* ===========================
     Actions
     =========================== */
  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  /* Primary CTA — the most prominent interactive element */
  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--blue-primary);
    background: var(--white-full);
    padding: 22px 48px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), box-shadow 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--blue-accent);
    z-index: -1;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-btn-primary:hover {
    color: var(--white-full);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .cta-btn-primary:hover::before {
    transform: scaleX(1);
  }

  .cta-btn-arrow {
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-btn-primary:hover .cta-btn-arrow {
    transform: translateX(4px);
  }

  /* Phone CTA */
  .cta-phone {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-phone:hover {
    color: var(--white-full);
  }

  .cta-phone-icon {
    flex-shrink: 0;
  }

  .cta-phone-label {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .cta-phone-number {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  /* ===========================
     Tagline
     =========================== */
  .cta-tagline {
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .tagline-text {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.4);
  }

  /* ===========================
     Responsive — 1200px
     =========================== */
  @media (max-width: 1200px) {
    .cta-inner {
      padding: 0 80px;
    }

    .cta-headline {
      font-size: 56px;
    }
  }

  /* ===========================
     Responsive — 1024px
     =========================== */
  @media (max-width: 1024px) {
    .products-cta {
      padding: 96px 0 80px;
    }

    .cta-inner {
      padding: 0 48px;
    }

    .cta-headline {
      font-size: 48px;
    }

    .cta-subtext {
      font-size: 17px;
    }
  }

  /* ===========================
     Responsive — 768px
     =========================== */
  @media (max-width: 768px) {
    .products-cta {
      padding: 80px 0 72px;
      background: linear-gradient(170deg, #0f2d5c 0%, var(--blue-primary) 45%, #1a4480 100%);
    }

    .cta-inner {
      padding: 0 28px;
    }

    .cta-rule {
      margin-bottom: 44px;
    }

    .cta-headline {
      font-size: 42px;
      line-height: 108%;
      margin-bottom: 20px;
    }

    .cta-subtext {
      font-size: 16px;
      margin-bottom: 40px;
    }

    .cta-btn-primary {
      font-size: 20px;
      padding: 22px 44px;
      width: 100%;
      justify-content: center;
    }

    .cta-actions {
      gap: 24px;
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
    }

    /* Phone — bigger tap target at tablet */
    .cta-phone {
      gap: 10px;
      padding: 14px 24px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 4px;
      width: 100%;
      justify-content: center;
      min-height: 56px;
    }

    .cta-phone-number {
      font-size: 20px;
    }

    .cta-tagline {
      margin-top: 60px;
      padding-top: 32px;
    }
  }

  /* ===========================
     Responsive — 480px
     =========================== */
  @media (max-width: 480px) {
    .products-cta {
      padding: 64px 0 56px;
      background: linear-gradient(175deg, #0c2650 0%, #1a5ba8 50%, #163d72 100%);
    }

    .cta-inner {
      padding: 0 20px;
    }

    .cta-rule {
      width: 48px;
      margin-bottom: 36px;
    }

    .cta-headline {
      font-size: 36px;
      line-height: 110%;
      margin-bottom: 16px;
    }

    .cta-subtext {
      font-size: 15px;
      line-height: 165%;
      margin-bottom: 36px;
    }

    .cta-actions {
      gap: 16px;
      max-width: none;
    }

    .cta-btn-primary {
      font-size: 19px;
      padding: 20px 32px;
      gap: 12px;
      width: 100%;
      justify-content: center;
      min-height: 64px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }

    .cta-btn-arrow {
      width: 22px;
      height: 22px;
    }

    /* Phone — unmissable tap target */
    .cta-phone {
      flex-wrap: nowrap;
      justify-content: center;
      gap: 10px;
      padding: 16px 20px;
      min-height: 56px;
      border: 1px solid rgba(255, 255, 255, 0.25);
      border-radius: 4px;
      width: 100%;
      color: rgba(255, 255, 255, 0.85);
    }

    .cta-phone-label {
      font-size: 12px;
    }

    .cta-phone-number {
      font-size: 19px;
      letter-spacing: 0.03em;
    }

    .cta-tagline {
      margin-top: 48px;
      padding-top: 28px;
    }

    .tagline-text {
      font-size: 11px;
      letter-spacing: 0.15em;
    }
  }

  /* ===========================
     Responsive — 375px (small phones)
     =========================== */
  @media (max-width: 375px) {
    .products-cta {
      padding: 56px 0 48px;
    }

    .cta-inner {
      padding: 0 16px;
    }

    .cta-rule {
      margin-bottom: 32px;
    }

    .cta-headline {
      font-size: 32px;
      line-height: 112%;
    }

    .cta-subtext {
      font-size: 14px;
      margin-bottom: 32px;
    }

    .cta-btn-primary {
      font-size: 17px;
      padding: 18px 24px;
      min-height: 60px;
    }

    .cta-phone {
      padding: 14px 16px;
      min-height: 52px;
    }

    .cta-phone-number {
      font-size: 18px;
    }

    .cta-tagline {
      margin-top: 40px;
      padding-top: 24px;
    }
  }
</style>
