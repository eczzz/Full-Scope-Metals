---

---

<section class="product-specs">
  <div class="specs-inner">

    <!-- Section Header -->
    <div class="specs-header scroll-reveal">
      <p class="specs-eyebrow">Quality & Specs</p>
      <h2 class="specs-headline"><span class="headline-accent">Built Right.</span><br />From Our Shop to Your Job Site.</h2>
      <div class="specs-headline-rule"></div>
    </div>

    <!-- Spec Blocks — staggered two-column layout -->
    <div class="specs-body">

      <!-- Row 1: Materials + Finish Systems -->
      <div class="specs-row">
        <div class="spec-block spec-block--materials scroll-reveal" style="--delay: 0.1s">
          <div class="spec-block-accent"></div>
          <div class="spec-block-content">
            <div class="spec-block-number-row">
              <span class="spec-big-number">29<span class="spec-number-sep">–</span>22</span>
              <span class="spec-big-unit">gauge</span>
            </div>
            <h3 class="spec-block-title">Materials</h3>
            <p class="spec-block-body">We work with anywhere from 29 to 22 gauge Galvalume steel, offering 29, 26, 24, and 22 gauge options. Every panel starts as premium coil stock. No seconds, no off-spec material.</p>
          </div>
        </div>

        <div class="spec-block spec-block--finishes scroll-reveal" style="--delay: 0.2s">
          <div class="spec-block-accent"></div>
          <div class="spec-block-content">
            <div class="spec-block-number-row">
              <span class="spec-big-number">40</span>
              <span class="spec-big-unit">year color retention</span>
            </div>
            <h3 class="spec-block-title">Finish Systems</h3>
            <p class="spec-block-body">Kynar 500/PVDF for 40-year color retention. SMP paint systems for cost-effective projects. Custom color matching available for architectural specs.</p>
          </div>
        </div>
      </div>

      <!-- Row 2: Fabrication (full-width) -->
      <div class="spec-block spec-block--fabrication scroll-reveal" style="--delay: 0.15s">
        <div class="spec-block-accent spec-block-accent--promise"></div>
        <div class="spec-block-content">
          <div class="spec-block-icon-row">
            <svg width="24" height="24" viewBox="0 0 512 512" fill="var(--blue-accent)" xmlns="http://www.w3.org/2000/svg">
              <path d="M495.9 166.6c3.2 8.7 .5 18.4-6.4 24.6l-43.3 39.4c1.1 8.3 1.7 16.8 1.7 25.4s-.6 17.1-1.7 25.4l43.3 39.4c6.9 6.2 9.6 15.9 6.4 24.6c-4.4 11.9-9.7 23.3-15.8 34.3l-3.2 5.6c-6.4 10.8-13.5 21.3-21.2 31.2c-5.9 7.6-15.3 10.9-24.5 8.7l-57.1-13.3c-13.2 10.1-27.5 18.8-42.8 25.8l-12.7 57.5c-2 9-9 16-18.2 18c-12 2.6-24.4 4-37.1 4s-25.2-1.3-37.1-4c-9.2-2-16.2-9-18.2-18l-12.7-57.5c-15.3-7-29.6-15.7-42.8-25.8l-57.1 13.3c-9.2 2.1-18.5-1.1-24.5-8.7c-7.7-9.9-14.8-20.3-21.2-31.2l-3.2-5.6c-6.1-11-11.4-22.4-15.8-34.3c-3.2-8.7-.5-18.4 6.4-24.6l43.3-39.4C64.6 273.1 64 264.6 64 256s.6-17.1 1.7-25.4L22.4 191.2c-6.9-6.2-9.6-15.9-6.4-24.6c4.4-11.9 9.7-23.3 15.8-34.3l3.2-5.6c6.4-10.8 13.5-21.3 21.2-31.2c5.9-7.6 15.3-10.9 24.5-8.7L137.8 100c13.2-10.1 27.5-18.8 42.8-25.8l12.7-57.5c2-9 9-16 18.2-18C223.5 1.3 235.9 0 248.6 0h14.7c12.7 0 25.2 1.3 37.1 4c9.2 2 16.2 9 18.2 18l12.7 57.5c15.3 7 29.6 15.7 42.8 25.8l57.1-13.3c9.2-2.1 18.5 1.1 24.5 8.7c7.7 9.9 14.8 20.3 21.2 31.2l3.2 5.6c6.1 11 11.4 22.4 15.8 34.3zM256 336a80 80 0 1 0 0-160 80 80 0 1 0 0 160z"/>
            </svg>
          </div>
          <h3 class="spec-block-title">Fabrication</h3>
          <p class="spec-block-body">Panels, trims, and flashing are roll-formed and brake-bent on our own equipment. CNC-controlled machines ensure consistent profiles every run.</p>
          <div class="spec-fabrication-badge">
            <span class="badge-label">Made in</span>
            <span class="badge-location">In-House</span>
          </div>
        </div>
      </div>

      <!-- Row 3: Tolerances + Lead Times -->
      <div class="specs-row">
        <div class="spec-block spec-block--tolerances scroll-reveal" style="--delay: 0.1s">
          <div class="spec-block-accent"></div>
          <div class="spec-block-content">
            <div class="spec-block-icon-row">
              <svg width="24" height="24" viewBox="0 0 512 512" fill="var(--blue-accent)" xmlns="http://www.w3.org/2000/svg">
                <path d="M256 0c36.8 0 68.8 20.7 84.9 51.1C373.8 41 411 49 437 75s34 63.3 23.9 96.1C491.3 187.2 512 219.2 512 256s-20.7 68.8-51.1 84.9C471 373.8 463 411 437 437s-63.3 34-96.1 23.9C324.8 491.3 292.8 512 256 512s-68.8-20.7-84.9-51.1C138.2 471 101 463 75 437s-34-63.3-23.9-96.1C20.7 324.8 0 292.8 0 256s20.7-68.8 51.1-84.9C41 138.2 49 101 75 75s63.3-34 96.1-23.9C187.2 20.7 219.2 0 256 0zM369 209c9.4-9.4 9.4-24.6 0-33.9s-24.6-9.4-33.9 0l-111 111-47-47c-9.4-9.4-24.6-9.4-33.9 0s-9.4 24.6 0 33.9l64 64c9.4 9.4 24.6 9.4 33.9 0L369 209z"/>
              </svg>
            </div>
            <h3 class="spec-block-title">Tolerances & Standards</h3>
            <p class="spec-block-body">We hold to manufacturer specifications on every cut, bend, and hem. Panels are inspected before they leave the shop floor.</p>
            <div class="spec-promise-line">
              <span class="promise-marker"></span>
              <span class="promise-text">Every panel inspected</span>
            </div>
            <div class="spec-promise-line">
              <span class="promise-marker"></span>
              <span class="promise-text">Manufacturer spec compliance</span>
            </div>
            <div class="spec-promise-line">
              <span class="promise-marker"></span>
              <span class="promise-text">Consistent profiles, every run</span>
            </div>
          </div>
        </div>

        <div class="spec-block spec-block--leadtimes scroll-reveal" style="--delay: 0.2s">
          <div class="spec-block-accent spec-block-accent--promise"></div>
          <div class="spec-block-content">
            <h3 class="spec-block-title">Lead Times</h3>
            <p class="spec-lead-intro">We aim to keep turnarounds tight.</p>

            <div class="lead-time-row">
              <div class="lead-time-days">
                <span class="lead-number">~5–7</span>
                <span class="lead-unit">business days</span>
              </div>
              <p class="lead-desc">Standard panels</p>
            </div>

            <div class="lead-time-row">
              <div class="lead-time-days">
                <span class="lead-number">~7–10</span>
                <span class="lead-unit">business days</span>
              </div>
              <p class="lead-desc">Custom trims & specialty profiles</p>
            </div>

            <div class="lead-time-rush">
              <span class="rush-badge">Rush Available</span>
              <span class="rush-text">Call us. We'll make it work.</span>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ===========================
     Section Container
     =========================== */
  .product-specs {
    background: #1c1f26;
    padding: 120px 0;
    overflow: hidden;
    position: relative;
    background-image:
      linear-gradient(to bottom, rgba(23, 23, 23, 0.88), rgba(28, 31, 38, 0.92)),
      url('/quality-and-specs-background.webp');
    background-size: cover;
    background-position: center;
  }

  /* Subtle top border */
  .product-specs::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 162, 233, 0.3) 30%,
      var(--blue-accent) 50%,
      rgba(0, 162, 233, 0.3) 70%,
      transparent 100%
    );
  }

  .specs-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
  }

  /* ===========================
     Section Header
     =========================== */
  .specs-header {
    margin-bottom: 80px;
    max-width: 720px;
  }

  .specs-eyebrow {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
  }

  .headline-accent {
    color: var(--blue-accent);
  }

  .specs-headline {
    font-family: var(--font-heading);
    font-size: 56px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 115%;
    margin-bottom: 24px;
  }

  .specs-headline-rule {
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, var(--blue-accent), var(--blue-primary));
  }

  /* ===========================
     Spec Rows
     =========================== */
  .specs-body {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .specs-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  /* ===========================
     Spec Block — Card
     =========================== */
  .spec-block {
    background: rgba(232, 232, 232, 0.03);
    border: 1px solid rgba(232, 232, 232, 0.06);
    position: relative;
    overflow: hidden;
    transition: border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  /* BUG FIX: merge opacity/transform into scoped transition for scroll-reveal */
  .spec-block.scroll-reveal {
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.1, 0.25, 1),
      transform 0.8s cubic-bezier(0.25, 0.1, 0.25, 1),
      border-color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1),
      background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
    transition-delay: var(--delay, 0s);
  }

  .spec-block:hover {
    border-color: rgba(0, 162, 233, 0.2);
    background: rgba(36, 93, 167, 0.06);
  }

  /* Left accent bar */
  .spec-block-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--blue-primary);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .spec-block:hover .spec-block-accent {
    transform: scaleY(1);
  }

  .spec-block-accent--promise {
    background: var(--blue-accent);
  }

  .spec-block-content {
    padding: 48px 44px;
  }

  /* ===========================
     Big Numbers (Materials, Finishes)
     =========================== */
  .spec-block-number-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }

  .spec-big-number {
    font-family: var(--font-heading);
    font-size: 72px;
    font-weight: 400;
    color: var(--blue-accent);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .spec-number-sep {
    color: var(--blue-primary);
    margin: 0 2px;
  }

  .spec-big-unit {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--white-muted);
  }

  /* ===========================
     Block Typography
     =========================== */
  .spec-block-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--white-full);
    margin-bottom: 14px;
  }

  .spec-block-body {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 175%;
  }

  .spec-block-icon-row {
    margin-bottom: 20px;
  }

  /* ===========================
     Fabrication Badge
     =========================== */
  .spec-fabrication-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 24px;
    padding: 14px 22px;
    border: 1px solid rgba(0, 162, 233, 0.15);
  }

  .badge-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--white-muted);
  }

  .badge-location {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--blue-accent);
  }

  /* ===========================
     Promise Lines (Tolerances)
     =========================== */
  .spec-promise-line {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(232, 232, 232, 0.06);
  }

  .spec-promise-line:first-of-type {
    margin-top: 32px;
    border-top: 1px solid rgba(232, 232, 232, 0.06);
  }

  .promise-marker {
    width: 8px;
    height: 8px;
    min-width: 8px;
    background: var(--blue-accent);
    border-radius: 50%;
  }

  .promise-text {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  /* ===========================
     Lead Times
     =========================== */
  .spec-lead-intro {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 175%;
    margin-bottom: 28px;
  }

  .lead-time-row {
    display: flex;
    align-items: baseline;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid rgba(232, 232, 232, 0.06);
  }

  .lead-time-row:first-of-type {
    border-top: 1px solid rgba(232, 232, 232, 0.06);
  }

  .lead-time-days {
    display: flex;
    align-items: baseline;
    gap: 8px;
    min-width: 180px;
  }

  .lead-number {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 400;
    color: var(--blue-accent);
    line-height: 1;
  }

  .lead-unit {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--white-muted);
  }

  .lead-desc {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--white);
    line-height: 155%;
  }

  .lead-time-rush {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    padding: 16px 20px;
    background: rgba(0, 162, 233, 0.08);
    border: 1px solid rgba(0, 162, 233, 0.2);
  }

  .rush-badge {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blue-accent);
    padding: 4px 12px;
    border: 1px solid var(--blue-accent);
    white-space: nowrap;
  }

  .rush-text {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--white);
  }

  /* ===========================
     Responsive — 1200px
     =========================== */
  @media (max-width: 1200px) {
    .specs-inner {
      padding: 0 80px;
    }

    .specs-headline {
      font-size: 48px;
    }

    .spec-big-number {
      font-size: 60px;
    }

    .spec-block-content {
      padding: 40px 36px;
    }

  }

  /* ===========================
     Responsive — 1024px
     =========================== */
  @media (max-width: 1024px) {
    .product-specs {
      padding: 80px 0;
    }

    .specs-inner {
      padding: 0 48px;
    }

    .specs-header {
      margin-bottom: 60px;
    }

    .specs-headline {
      font-size: 40px;
    }

    .specs-row {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .lead-time-days {
      min-width: 160px;
    }
  }

  /* ===========================
     Responsive — 768px
     =========================== */
  @media (max-width: 768px) {
    .product-specs {
      padding: 64px 0;
    }

    .specs-inner {
      padding: 0 24px;
    }

    .specs-header {
      margin-bottom: 48px;
    }

    .specs-headline {
      font-size: 32px;
    }

    .specs-headline-rule {
      width: 60px;
    }

    .specs-body {
      gap: 32px;
    }

    .spec-block-content {
      padding: 32px 28px;
    }

    .spec-big-number {
      font-size: 48px;
    }

    .spec-big-unit {
      font-size: 14px;
    }

    /* Lead times stack — number on top, description below */
    .lead-time-row {
      flex-direction: column;
      gap: 6px;
      padding: 18px 0;
    }

    .lead-time-days {
      min-width: auto;
    }

    .lead-number {
      font-size: 32px;
    }

    .lead-time-rush {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    /* Tolerances — more breathing room for scanning */
    .spec-promise-line {
      padding: 12px 0;
    }

    /* Left accent always visible on touch */
    .spec-block-accent {
      transform: scaleY(1);
    }

    .spec-block-accent--promise {
      background: var(--blue-accent);
    }
  }

  /* ===========================
     Responsive — 480px
     =========================== */
  @media (max-width: 480px) {
    .product-specs {
      padding: 48px 0;
    }

    .specs-inner {
      padding: 0 16px;
    }

    .specs-header {
      margin-bottom: 36px;
    }

    .specs-eyebrow {
      font-size: 16px;
    }

    .specs-headline {
      font-size: 26px;
    }

    .specs-body {
      gap: 24px;
    }

    .spec-block-content {
      padding: 24px 20px;
    }

    /* Fluid spec numbers — authoritative at 375px (~40px), solid at 480px */
    .spec-big-number {
      font-size: clamp(38px, 10.5vw, 48px);
    }

    .spec-block-title {
      font-size: 20px;
    }

    .spec-block-body {
      font-size: 15px;
    }

    .badge-location {
      font-size: 15px;
    }

    /* Lead time numbers — contractor needs to see these instantly
       30px minimum keeps them scannable one-handed */
    .lead-number {
      font-size: 30px;
    }

    .lead-desc {
      font-size: 15px;
    }

    /* Lead time rows — tighter vertical rhythm */
    .lead-time-row {
      padding: 14px 0;
    }

    .lead-time-rush {
      padding: 14px 16px;
    }

    /* Promise checkmarks — scannable list */
    .spec-promise-line {
      padding: 11px 0;
      gap: 12px;
    }

    .promise-text {
      font-size: 13px;
    }

    .rush-badge {
      font-size: 11px;
    }

    .rush-text {
      font-size: 14px;
    }
  }
</style>
