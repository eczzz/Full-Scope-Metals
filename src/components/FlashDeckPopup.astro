<aside class="fd-popup" id="fd-popup" aria-hidden="true" aria-label="Flash Deck announcement">
  <div class="fd-popup-overlay" id="fd-popup-overlay"></div>

  <div class="fd-popup-panel" role="dialog" aria-modal="false" aria-labelledby="fd-popup-heading">
    <button class="fd-popup-close" id="fd-popup-close" aria-label="Close Flash Deck announcement">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="fd-popup-accent"></div>

    <div class="fd-popup-content">
      <p class="fd-popup-label">Now Carrying</p>

      <img
        src="/flash-deck-logo-3.webp"
        alt="Flash Deck logo"
        class="fd-popup-logo"
        width="800"
        height="221"
      />

      <h2 class="fd-popup-heading" id="fd-popup-heading">
        Seals the <span class="fd-popup-accent-text">Whole Roof.</span>
      </h2>

      <div class="fd-popup-badge">
        <svg width="18" height="18" viewBox="0 0 512 512" fill="currentColor"><path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.7 82.8c22 9.3 38.4 31 38.3 57.2c-.5 99.2-41.3 280.7-213.6 363.2c-16.7 8-36.1 8-52.8 0C57.3 420.7 16.5 239.2 16 140c-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.8 1 251.4 0 256 0z"/></svg>
        <span>One of Only Two Distributors in the U.S.</span>
      </div>

      <p class="fd-popup-body">
        Full Scope Metals is now carrying Flash Deck™, a butyl-based underlayment system that seals the roof as one continuous barrier. Better chemistry, better protection.
      </p>

      <div class="fd-popup-cta-row">
        <a href="/flashdeck" class="fd-popup-cta">
          <span>Learn More</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</aside>

<script>
  function initFlashDeckPopup() {
    const popup = document.getElementById('fd-popup');
    const overlay = document.getElementById('fd-popup-overlay');
    const closeBtn = document.getElementById('fd-popup-close');

    if (!popup || !overlay || !closeBtn) return;
    if (popup.dataset.fdInitialized === '1') return;
    popup.dataset.fdInitialized = '1';

    const STORAGE_KEY = 'fd-popup-dismissed-session';
    const SCROLL_THRESHOLD = 500;

    const showPopup = () => {
      if (sessionStorage.getItem(STORAGE_KEY) === '1') return;
      popup.classList.add('fd-popup--open');
      popup.setAttribute('aria-hidden', 'false');
    };

    const hidePopup = () => {
      popup.classList.remove('fd-popup--open');
      popup.setAttribute('aria-hidden', 'true');
      sessionStorage.setItem(STORAGE_KEY, '1');
    };

    const onScroll = () => {
      if (window.scrollY > SCROLL_THRESHOLD) {
        showPopup();
        window.removeEventListener('scroll', onScroll);
      }
    };

    closeBtn.addEventListener('click', hidePopup);
    overlay.addEventListener('click', hidePopup);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && popup.classList.contains('fd-popup--open')) {
        hidePopup();
      }
    });

    if (window.scrollY > SCROLL_THRESHOLD) {
      showPopup();
    } else {
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  }

  document.addEventListener('astro:page-load', initFlashDeckPopup);
</script>

<style>
  :root {
    --fd-yellow: #ffc50b;
  }

  .fd-popup {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    pointer-events: none;
    visibility: hidden;
  }

  .fd-popup--open {
    visibility: visible;
    pointer-events: auto;
  }

  .fd-popup-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .fd-popup--open .fd-popup-overlay {
    opacity: 1;
  }

  .fd-popup-panel {
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    min-width: 480px;
    max-width: 720px;
    height: 100%;
    background: var(--bg);
    display: flex;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
    box-shadow: -12px 0 48px rgba(0, 0, 0, 0.4);
  }

  .fd-popup--open .fd-popup-panel {
    transform: translateX(0);
  }

  /* Yellow accent stripe */
  .fd-popup-accent {
    width: 6px;
    background: var(--fd-yellow);
    flex-shrink: 0;
  }

  /* Close button — intentionally prominent */
  .fd-popup-close {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    background: var(--fd-yellow);
    border: none;
    color: var(--black);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .fd-popup-close:hover {
    background: #ffd33e;
    transform: scale(1.05);
  }

  .fd-popup-close:focus-visible {
    outline: 3px solid var(--white-full);
    outline-offset: 3px;
  }

  .fd-popup-content {
    flex: 1;
    padding: 80px 64px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow-y: auto;
  }

  .fd-popup-label {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
    letter-spacing: 0.04em;
  }

  .fd-popup-logo {
    display: block;
    height: 72px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    align-self: flex-start;
    margin-bottom: 20px;
  }

  .fd-popup-heading {
    font-family: var(--font-heading);
    font-size: 64px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 105%;
    margin-bottom: 24px;
  }

  .fd-popup-accent-text {
    color: var(--fd-yellow);
  }

  .fd-popup-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    background: rgba(255, 197, 11, 0.08);
    border: 1px solid rgba(255, 197, 11, 0.3);
    color: var(--fd-yellow);
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 24px;
    align-self: flex-start;
  }

  .fd-popup-badge svg {
    flex-shrink: 0;
  }

  .fd-popup-body {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 165%;
    margin-bottom: 36px;
    max-width: 480px;
  }

  /* CTA button — yellow-themed variant of site outline button */
  .fd-popup-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--black);
    background: var(--fd-yellow);
    border: 1px solid var(--fd-yellow);
    padding: 16px 28px;
    height: 56px;
    text-decoration: none;
    cursor: pointer;
    align-self: flex-start;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1), border-color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .fd-popup-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: var(--bg);
    z-index: -1;
    transition: width 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .fd-popup-cta:hover {
    color: var(--fd-yellow);
    border-color: var(--fd-yellow);
  }

  .fd-popup-cta:hover::before {
    width: 100%;
  }

  .fd-popup-cta svg {
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .fd-popup-cta:hover svg {
    transform: translateX(4px);
  }

  /* ===========================
     Responsive
     =========================== */
  @media (max-width: 1024px) {
    .fd-popup-panel {
      width: 65%;
      min-width: 0;
    }

    .fd-popup-content {
      padding: 72px 48px 56px;
    }

    .fd-popup-heading {
      font-size: 52px;
    }
  }

  @media (max-width: 768px) {
    .fd-popup-panel {
      width: 100%;
      max-width: none;
    }

    .fd-popup-close {
      top: 16px;
      right: 16px;
      width: 48px;
      height: 48px;
    }

    .fd-popup-content {
      padding: 80px 28px 40px;
    }

    .fd-popup-label {
      font-size: 16px;
    }

    .fd-popup-logo {
      height: 52px;
      margin-bottom: 16px;
    }

    .fd-popup-heading {
      font-size: 40px;
    }

    .fd-popup-body {
      font-size: 15px;
    }

    .fd-popup-cta {
      font-size: 16px;
      height: 52px;
    }
  }

  @media (max-width: 480px) {
    .fd-popup-content {
      padding: 72px 20px 32px;
    }

    .fd-popup-heading {
      font-size: 32px;
    }

    .fd-popup-badge {
      font-size: 11px;
      padding: 6px 12px;
    }
  }
</style>
