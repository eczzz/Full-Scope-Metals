---
// Reusable social media links (Instagram + Facebook) in true brand colors.
// variant controls layout/sizing per placement:
//   "inline" | "sidebar" | "footer" | "menu" | "banner"
const { variant = "inline", label } = Astro.props;

// Unique id per instance so multiple copies on a page don't share a gradient def.
const g = globalThis as unknown as { __socialUid?: number };
g.__socialUid = (g.__socialUid || 0) + 1;
const uid = `ig-grad-${g.__socialUid}`;
---

<div class={`social-links social-${variant}`}>
  {label && <span class="social-label">{label}</span>}
  <div class="social-icons">
    <a
      href="https://www.instagram.com/fullscopemetals/"
      target="_blank"
      rel="noopener"
      class="social-icon"
      aria-label="Full Scope Metals on Instagram"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <defs>
          <radialGradient id={uid} cx="30%" cy="107%" r="150%">
            <stop offset="0%" stop-color="#fdf497" />
            <stop offset="5%" stop-color="#fdf497" />
            <stop offset="45%" stop-color="#fd5949" />
            <stop offset="60%" stop-color="#d6249f" />
            <stop offset="90%" stop-color="#285AEB" />
          </radialGradient>
        </defs>
        <rect x="2" y="2" width="20" height="20" rx="6" fill={`url(#${uid})`} />
        <circle cx="12" cy="12" r="4.2" fill="none" stroke="#fff" stroke-width="1.8" />
        <circle cx="17.3" cy="6.7" r="1.25" fill="#fff" />
      </svg>
    </a>
    <a
      href="https://www.facebook.com/FullScopeMetals"
      target="_blank"
      rel="noopener"
      class="social-icon"
      aria-label="Full Scope Metals on Facebook"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="11" fill="#1877F2" />
        <path fill="#fff" d="M13.5 21v-7h2.3l.4-2.8h-2.7V9.4c0-.8.2-1.4 1.4-1.4h1.5V5.5c-.3 0-1.2-.1-2.2-.1-2.2 0-3.7 1.3-3.7 3.8v2.1H8.2V14h2.3v7h3z" />
      </svg>
    </a>
  </div>
</div>

<style>
  .social-links {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .social-label {
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--white);
  }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .social-icon {
    display: inline-flex;
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .social-icon svg {
    width: 28px;
    height: 28px;
  }

  .social-icon:hover {
    transform: translateY(-2px);
  }

  /* ===== Inline variant (sits in an info-row value slot) ===== */
  .social-inline {
    gap: 0;
  }

  .social-inline .social-icons {
    gap: 16px;
  }

  /* ===== Sidebar variant (Contact page) ===== */
  .social-sidebar {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .social-sidebar .social-label {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--white-muted);
  }

  /* ===== Footer variant ===== */
  .social-footer .social-icon svg {
    width: 30px;
    height: 30px;
  }

  /* ===== Menu variant (mobile menu) ===== */
  .social-menu {
    justify-content: center;
    width: 100%;
    gap: 28px;
  }

  .social-menu .social-icons {
    gap: 28px;
  }

  .social-menu .social-icon svg {
    width: 32px;
    height: 32px;
  }

  /* ===== Banner variant (sticky top banner) ===== */
  .social-banner .social-icons {
    gap: 16px;
  }

  .social-banner .social-icon svg {
    width: 24px;
    height: 24px;
  }

  /* On mobile the contact sidebar goes compact: label left, icons right */
  @media (max-width: 768px) {
    .social-sidebar {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    }

    .social-sidebar .social-label {
      font-size: 12px;
      margin: 0;
    }
  }
</style>
