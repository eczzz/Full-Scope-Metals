---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Flash Deck™ - Full Scope Metals | Exclusive U.S. Distributor"
  description="Full Scope Metals is one of only two distributors in the country carrying Flash Deck™ — a butyl-based roofing underlayment that seals the roof as one continuous barrier."
>
  <Header />

  <main>
    <!-- ===== Hero ===== -->
    <section class="fd-hero">
      <div class="fd-hero-bg">
        <img
          src="/full-scope-contact-hero-bg.webp"
          alt="Full Scope Metals shop"
          class="fd-hero-bg-img"
          width="1440"
          height="600"
          fetchpriority="high"
        />
        <div class="fd-hero-overlay"></div>
      </div>

      <div class="fd-hero-inner">
        <div class="fd-hero-primary">
          <p class="section-label hero-fade-up" style="--hero-delay: 0.1s">Partner Product</p>

          <img
            src="/flash-deck-logo-3.webp"
            alt="Flash Deck logo"
            class="fd-hero-logo hero-fade-up"
            style="--hero-delay: 0.2s"
            width="800"
            height="221"
          />

          <h1 class="fd-hero-headline hero-fade-up" style="--hero-delay: 0.3s">
            <span class="fd-accent">Built Different.</span>
          </h1>

          <p class="fd-hero-sub hero-fade-up" style="--hero-delay: 0.5s">
            A butyl-based underlayment system that seals the whole roof as one continuous barrier. We're one of only two distributors in the country carrying it.
          </p>

          <div class="fd-cta-row hero-fade-up" style="--hero-delay: 0.7s">
            <a href="#fd-contact" class="fd-cta-primary">Request a Quote</a>
            <a href="tel:9702812982" class="fd-cta-secondary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2"/>
              </svg>
              <span>(970) 281-2982</span>
            </a>
          </div>
        </div>

        <div class="fd-hero-badge hero-fade-up" style="--hero-delay: 0.6s">
          <div class="fd-badge-accent"></div>
          <div class="fd-badge-content">
            <svg width="24" height="24" viewBox="0 0 512 512" fill="currentColor"><path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.7 82.8c22 9.3 38.4 31 38.3 57.2c-.5 99.2-41.3 280.7-213.6 363.2c-16.7 8-36.1 8-52.8 0C57.3 420.7 16.5 239.2 16 140c-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.8 1 251.4 0 256 0z"/></svg>
            <p class="fd-badge-title">Exclusive Distribution</p>
            <p class="fd-badge-detail">Only Two Authorized Dealers<br />in the United States</p>
          </div>
        </div>
      </div>

      <div class="fd-hero-divider"></div>
    </section>

    <!-- ===== What It Is ===== -->
    <section class="fd-what">
      <div class="fd-what-inner">
        <div class="fd-what-intro scroll-reveal">
          <p class="section-label">What It Is</p>
          <h2 class="fd-section-headline">A Sealed Roof. <span class="fd-accent">Start to Finish.</span></h2>
          <p class="fd-section-body">
            Flash Deck™ isn't a single product. It's a self-adhered underlayment system where every component bonds chemically and physically to the next. No seams to worry about. No over/under layering debates. One unified seal from drip edge to ridge.
          </p>
        </div>

        <div class="fd-carousel">
          <div class="fd-carousel-track" id="fd-carousel-track">
            <div class="fd-carousel-slide fd-carousel-slide--active" data-slide="0">
              <img src="/flash-deck-gallery-1.webp" alt="Flash Deck underlayment installation detail" width="2000" height="1152" />
            </div>
            <div class="fd-carousel-slide" data-slide="1">
              <img src="/flash-deck-gallery-2.webp" alt="Flash Deck sealed roof perimeter" width="2000" height="1152" loading="lazy" />
            </div>
            <div class="fd-carousel-slide" data-slide="2">
              <img src="/flash-deck-gallery-3.webp" alt="Flash Deck safety yellow edge visibility" width="2000" height="1152" loading="lazy" />
            </div>
            <div class="fd-carousel-slide" data-slide="3">
              <img src="/flash-deck-gallery-4.webp" alt="Flash Deck on a finished job site" width="2000" height="1152" loading="lazy" />
            </div>
          </div>

          <button class="fd-carousel-nav fd-carousel-nav--prev" id="fd-carousel-prev" aria-label="Previous image">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="fd-carousel-nav fd-carousel-nav--next" id="fd-carousel-next" aria-label="Next image">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="fd-carousel-dots" role="tablist" aria-label="Flash Deck image gallery">
            <button class="fd-carousel-dot fd-carousel-dot--active" data-dot="0" aria-label="Show image 1"></button>
            <button class="fd-carousel-dot" data-dot="1" aria-label="Show image 2"></button>
            <button class="fd-carousel-dot" data-dot="2" aria-label="Show image 3"></button>
            <button class="fd-carousel-dot" data-dot="3" aria-label="Show image 4"></button>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Why It's Different ===== -->
    <section class="fd-why">
      <div class="fd-why-inner">
        <div class="fd-why-header scroll-reveal">
          <p class="section-label">Why It's Different</p>
          <h2 class="fd-section-headline">Built Past <span class="fd-accent">Code Minimum.</span></h2>
        </div>

        <div class="fd-points">
          <div class="fd-point scroll-reveal" style="--delay: 0.1s">
            <span class="fd-point-number">01</span>
            <div class="fd-point-content">
              <h3 class="fd-point-title">Code Plus Integration</h3>
              <p class="fd-point-desc">Reinforces the vulnerable perimeters where traditional underlayments typically fail. Protection where it matters most.</p>
            </div>
          </div>

          <div class="fd-point scroll-reveal" style="--delay: 0.15s">
            <span class="fd-point-number">02</span>
            <div class="fd-point-content">
              <h3 class="fd-point-title">100% Self-Adhered</h3>
              <p class="fd-point-desc">Every layer bonds to the next. The whole system functions as one continuous seal instead of a stack of separate layers.</p>
            </div>
          </div>

          <div class="fd-point scroll-reveal" style="--delay: 0.2s">
            <span class="fd-point-number">03</span>
            <div class="fd-point-content">
              <h3 class="fd-point-title">Butyl-Based Chemistry</h3>
              <p class="fd-point-desc">No asphalt. No cold-weather issues. No granule loss. Premium performance that holds up where other underlayments give out.</p>
            </div>
          </div>

          <div class="fd-point scroll-reveal" style="--delay: 0.25s">
            <span class="fd-point-number">04</span>
            <div class="fd-point-content">
              <h3 class="fd-point-title">Built for the Crew</h3>
              <p class="fd-point-desc">High-visibility safety yellow edges reduce fatigue and improve jobsite awareness. Designed with the install in mind.</p>
            </div>
          </div>

          <div class="fd-point scroll-reveal" style="--delay: 0.3s">
            <span class="fd-point-number">05</span>
            <div class="fd-point-content">
              <h3 class="fd-point-title">Certified Contractor Support</h3>
              <p class="fd-point-desc">Extended warranties, direct technical support, and rebates for certified installers. Backing you up after the roof is on.</p>
            </div>
          </div>

          <div class="fd-point scroll-reveal" style="--delay: 0.35s">
            <span class="fd-point-number">06</span>
            <div class="fd-point-content">
              <h3 class="fd-point-title">Priced to Actually Use</h3>
              <p class="fd-point-desc">Elite-grade protection at shingle-market pricing. Premium performance you can actually put on the bid.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTA strip ===== -->
    <section class="fd-strip">
      <div class="fd-strip-inner scroll-reveal">
        <div class="fd-strip-text">
          <h2 class="fd-strip-headline">Want the full picture?</h2>
          <p class="fd-strip-body">Call us directly and we'll walk you through specs, pricing, and whether Flash Deck™ is the right fit for your next project.</p>
        </div>
        <div class="fd-strip-cta">
          <a href="tel:9702812982" class="fd-cta-primary fd-cta-primary--large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.09 9.81 19.79 19.79 0 01.12 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>(970) 281-2982</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== Contact ===== -->
    <div id="fd-contact">
      <ContactSection />
    </div>

    <Footer />
  </main>
</BaseLayout>

<script>
  function initFlashDeckCarousel() {
    const carousel = document.querySelector<HTMLElement>('.fd-carousel');
    if (!carousel || carousel.dataset.fdCarouselInitialized === '1') return;

    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.fd-carousel-slide'));
    const dots = Array.from(carousel.querySelectorAll<HTMLElement>('.fd-carousel-dot'));
    const prevBtn = carousel.querySelector<HTMLButtonElement>('.fd-carousel-nav--prev');
    const nextBtn = carousel.querySelector<HTMLButtonElement>('.fd-carousel-nav--next');

    if (!slides.length || !dots.length || !prevBtn || !nextBtn) return;
    carousel.dataset.fdCarouselInitialized = '1';

    const AUTO_ADVANCE_MS = 6000;
    const total = slides.length;
    let current = 0;
    let autoAdvance: number | null = null;

    const goTo = (index: number) => {
      current = (index + total) % total;
      slides.forEach((slide, i) => slide.classList.toggle('fd-carousel-slide--active', i === current));
      dots.forEach((dot, i) => dot.classList.toggle('fd-carousel-dot--active', i === current));
    };

    const next = () => goTo(current + 1);
    const prev = () => goTo(current - 1);

    const stopAutoAdvance = () => {
      if (autoAdvance !== null) {
        window.clearInterval(autoAdvance);
        autoAdvance = null;
      }
    };

    const startAutoAdvance = () => {
      stopAutoAdvance();
      autoAdvance = window.setInterval(next, AUTO_ADVANCE_MS);
    };

    nextBtn.addEventListener('click', () => { next(); startAutoAdvance(); });
    prevBtn.addEventListener('click', () => { prev(); startAutoAdvance(); });

    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => { goTo(idx); startAutoAdvance(); });
    });

    carousel.addEventListener('pointerenter', stopAutoAdvance);
    carousel.addEventListener('pointerleave', startAutoAdvance);

    // Stop auto-advance when leaving this page via view transition
    document.addEventListener('astro:before-swap', stopAutoAdvance, { once: true });

    startAutoAdvance();
  }

  document.addEventListener('astro:page-load', initFlashDeckCarousel);
</script>

<style>
  :root {
    --fd-yellow: #ffc50b;
  }

  /* ===========================
     Hero Load Animations
     =========================== */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes dividerExpand {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  .hero-fade-up {
    opacity: 0;
    animation: heroFadeUp 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: var(--hero-delay, 0s);
  }

  .section-label {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 20px;
  }

  .fd-accent {
    color: var(--fd-yellow);
  }

  /* ===========================
     Hero
     =========================== */
  .fd-hero {
    position: relative;
    background: var(--bg);
    overflow: hidden;
    min-height: 560px;
  }

  .fd-hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .fd-hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .fd-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, rgba(23, 23, 23, 0.96) 0%, rgba(23, 23, 23, 0.9) 50%, rgba(23, 23, 23, 0.78) 100%),
      linear-gradient(to bottom, rgba(23, 23, 23, 1) 0%, transparent 20%, transparent 80%, rgba(23, 23, 23, 1) 100%);
  }

  .fd-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 96px 100px 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 64px;
  }

  .fd-hero-primary {
    flex: 1;
    min-width: 0;
  }

  .fd-hero-logo {
    display: block;
    width: auto;
    height: auto;
    max-height: 88px;
    max-width: 100%;
    margin-bottom: 24px;
  }

  .fd-hero-headline {
    font-family: var(--font-heading);
    font-size: 76px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 105%;
    margin-bottom: 28px;
  }

  .fd-tm {
    font-size: 0.5em;
    vertical-align: super;
    letter-spacing: 0;
    color: var(--fd-yellow);
  }

  .fd-hero-sub {
    font-family: var(--font-body);
    font-size: 19px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 165%;
    max-width: 560px;
    margin-bottom: 36px;
  }

  /* ===========================
     Hero CTA Row
     =========================== */
  .fd-cta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .fd-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--black);
    background: var(--fd-yellow);
    border: 1px solid var(--fd-yellow);
    padding: 16px 26px;
    height: 56px;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1), border-color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .fd-cta-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: var(--bg);
    z-index: -1;
    transition: width 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .fd-cta-primary:hover {
    color: var(--fd-yellow);
  }

  .fd-cta-primary:hover::before {
    width: 100%;
  }

  .fd-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    border: 1px solid rgba(232, 232, 232, 0.3);
    padding: 16px 26px;
    height: 56px;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .fd-cta-secondary:hover {
    color: var(--fd-yellow);
    border-color: var(--fd-yellow);
  }

  /* ===========================
     Exclusive Distribution Badge
     =========================== */
  .fd-hero-badge {
    position: relative;
    display: flex;
    align-self: center;
    flex-shrink: 0;
    width: 320px;
  }

  .fd-badge-accent {
    width: 4px;
    background: var(--fd-yellow);
    flex-shrink: 0;
  }

  .fd-badge-content {
    padding: 28px 28px;
    background: rgba(23, 23, 23, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 197, 11, 0.2);
    border-left: none;
    flex: 1;
  }

  .fd-badge-content svg {
    color: var(--fd-yellow);
    margin-bottom: 12px;
  }

  .fd-badge-title {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fd-yellow);
    margin-bottom: 8px;
  }

  .fd-badge-detail {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 130%;
  }

  .fd-hero-divider {
    width: 100%;
    height: 18px;
    background: var(--fd-yellow);
    transform-origin: left;
    transform: scaleX(0);
    animation: dividerExpand 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: 0.85s;
    position: relative;
    z-index: 1;
  }

  /* ===========================
     What Section
     =========================== */
  .fd-what {
    background: var(--bg);
    padding: 100px 0;
  }

  .fd-what-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .fd-section-headline {
    font-family: var(--font-heading);
    font-size: 56px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 108%;
    margin-bottom: 28px;
  }

  .fd-section-body {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 170%;
    max-width: 520px;
  }

  /* ===========================
     Carousel
     =========================== */
  .fd-carousel {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: rgba(23, 23, 23, 0.4);
    border: 2px solid rgba(255, 197, 11, 0.35);
    overflow: hidden;
  }

  /* Corner accents — keep the Flash Deck visual signature */
  .fd-carousel::before,
  .fd-carousel::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 24px;
    background: var(--fd-yellow);
    z-index: 3;
    pointer-events: none;
  }

  .fd-carousel::before {
    top: -2px;
    left: -2px;
  }

  .fd-carousel::after {
    bottom: -2px;
    right: -2px;
  }

  .fd-carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .fd-carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);
    pointer-events: none;
  }

  .fd-carousel-slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  .fd-carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Nav arrows */
  .fd-carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background: rgba(23, 23, 23, 0.7);
    border: 1px solid rgba(255, 197, 11, 0.4);
    color: var(--fd-yellow);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }

  .fd-carousel-nav:hover {
    background: var(--fd-yellow);
    border-color: var(--fd-yellow);
    color: var(--black);
  }

  .fd-carousel-nav:focus-visible {
    outline: 2px solid var(--fd-yellow);
    outline-offset: 3px;
  }

  .fd-carousel-nav--prev {
    left: 16px;
  }

  .fd-carousel-nav--next {
    right: 16px;
  }

  /* Dots */
  .fd-carousel-dots {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    padding: 8px 14px;
    background: rgba(23, 23, 23, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 2;
  }

  .fd-carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 197, 11, 0.35);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .fd-carousel-dot:hover {
    background: rgba(255, 197, 11, 0.6);
  }

  .fd-carousel-dot--active {
    background: var(--fd-yellow);
    transform: scale(1.2);
  }

  .fd-carousel-dot:focus-visible {
    outline: 2px solid var(--fd-yellow);
    outline-offset: 2px;
  }

  /* ===========================
     Why Section
     =========================== */
  .fd-why {
    background: var(--bg);
    padding: 80px 0 120px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .fd-why-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 100px;
  }

  .fd-why-header {
