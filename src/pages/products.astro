---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ProductsHero from '../components/products/ProductsHero.astro';
import ProductCategories from '../components/products/ProductCategories.astro';
import ProductSpecs from '../components/products/ProductSpecs.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Products - Full Scope Metals | Custom Panels, Trims & Accessories"
  description="Seven product categories built and sourced for metal roofing contractors. Roof panels, wall panels, trims and flashing, fasteners, sealants, snow retention, and underlayments. Custom fabricated in Kremmling, Colorado."
>
  <Header />

  <main>
    <ProductsHero />

    <ProductCategories />

    <ProductSpecs />

    <!-- Section 3: Custom Fabrication / Process -->

    <ContactSection />

    <Footer />
  </main>
</BaseLayout>
