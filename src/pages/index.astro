---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import WhoWeAre from '../components/WhoWeAre.astro';
import Products from '../components/Products.astro';
import ByTheNumbers from '../components/ByTheNumbers.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Full Scope Metals — Custom Metal Roofing Products">
  <Header />

  <main>
    <!-- Hero Text Block -->
    <section class="hero-text">
      <div class="hero-text-inner">
        <p class="tagline hero-fade-up" style="--hero-delay: 0.2s">Based in Kremmling, Colorado</p>
        <h1 class="headline hero-fade-up" style="--hero-delay: 0.4s">
          Custom Metal Roofing Products. Built by People Who've Installed Them.
        </h1>

        <div class="subtext-row hero-fade-up" style="--hero-delay: 0.6s">
          <div class="subtext-left">
            <div class="accent-line"></div>
            <p class="subtext">
              From our Colorado shop to your job site. Panels, trims, and accessories fabricated to spec, on your timeline.
            </p>
          </div>

          <div class="cta-group">
            <a href="/contact" class="cta-outline">Get a Quote</a>
            <a href="/contact" class="cta-arrow" aria-label="Get a quote">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Blue Divider -->
    <div class="blue-divider"></div>

    <!-- Hero Image -->
    <section class="hero-image">
      <img
        src="/full-scope-metals-hero.webp"
        alt="Standing seam metal roof panels installed on a modern building"
        width="1441"
        height="380"
      />
    </section>

    <WhoWeAre />
    <Products />
    <ByTheNumbers />
    <ContactSection />
    <Footer />
  </main>
</BaseLayout>

<style>
  /* Hero Load Animations */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes dividerExpand {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }

  @keyframes heroImageFade {
    from {
      opacity: 0;
      transform: scale(1.03);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .hero-fade-up {
    opacity: 0;
    animation: heroFadeUp 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: var(--hero-delay, 0s);
  }

  .blue-divider {
    transform-origin: left;
    transform: scaleX(0);
    animation: dividerExpand 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: 0.8s;
  }

  .hero-image img {
    opacity: 0;
    animation: heroImageFade 1s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: 0.9s;
  }

  /* Hero Text Block */
  .hero-text {
    background: var(--bg);
    padding: 24px 0 60px;
  }

  .hero-text-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 126px;
  }

  .tagline {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 12px;
  }

  .headline {
    font-family: var(--font-heading);
    font-size: 86px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white-full);
    line-height: 110%;
    max-width: 1179px;
  }

  .subtext-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 40px;
    gap: 40px;
  }

  .subtext-left {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .accent-line {
    width: 2px;
    height: 48px;
    background: var(--blue-primary);
    flex-shrink: 0;
    margin-top: 4px;
    transition: height 0.4s cubic-bezier(0.25, 0.1, 0.25, 1), background 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .subtext {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    color: var(--white-muted);
    line-height: 1.5;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .subtext-left:hover .accent-line {
    background: var(--blue-accent);
    height: 56px;
  }

  .subtext-left:hover .subtext {
    color: var(--white-full);
  }

  .cta-group {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .cta-outline {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--white);
    border: 1px solid var(--white);
    background: transparent;
    padding: 16px 26px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    white-space: nowrap;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-outline::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: var(--white);
    z-index: -1;
    transition: width 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-outline:hover {
    color: var(--bg);
  }

  .cta-outline:hover::before {
    width: 100%;
  }

  .cta-arrow {
    width: 60px;
    height: 60px;
    background: transparent;
    border: 1px solid var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .cta-arrow svg {
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .cta-arrow:hover {
    background: var(--blue-accent);
    border-color: var(--blue-accent);
    color: var(--black);
  }

  .cta-arrow:hover svg {
    transform: translate(3px, -3px);
  }

  /* Blue Divider */
  .blue-divider {
    width: 100%;
    height: 18px;
    background: var(--blue-primary);
  }

  /* Hero Image */
  .hero-image {
    width: 100%;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 380px;
    object-fit: cover;
    display: block;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .hero-text-inner {
      padding: 0 48px;
    }

    .headline {
      font-size: 56px;
    }

    .subtext {
      font-size: 18px;
    }

    .hero-image img {
      height: 300px;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-text {
      padding: 48px 0 40px;
    }

    .hero-text-inner {
      padding: 0 24px;
    }

    .headline {
      font-size: 36px;
    }

    .subtext-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
    }

    .subtext {
      font-size: 16px;
    }

    .cta-outline {
      font-size: 16px;
      padding: 14px 20px;
      height: 52px;
    }

    .cta-arrow {
      width: 52px;
      height: 52px;
    }

    .blue-divider {
      height: 12px;
    }

    .hero-image img {
      height: 220px;
    }
  }
</style>
