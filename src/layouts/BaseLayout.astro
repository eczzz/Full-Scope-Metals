---
import '@fontsource/oswald/400.css';
import '@fontsource/oswald/500.css';
import '@fontsource/oswald/700.css';
import '@fontsource/montserrat/400.css';
import '@fontsource/montserrat/500.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import FlashDeckPopup from '../components/FlashDeckPopup.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Full Scope Metals - Custom metal roofing products built by people who've installed them. Based in Kremmling, Colorado." } = Astro.props;

const pathname = Astro.url.pathname;
const isFlashDeckPage = pathname === '/flashdeck' || pathname === '/flashdeck/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href="" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <ClientRouter />
    <title>{title}</title>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-T37CW9Q39S"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-T37CW9Q39S');
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />

    <!-- Structured Data: Local Business / Roofing Contractor -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "RoofingContractor",
      "name": "Full Scope Metals",
      "description": "Custom metal roofing products fabricated and sourced for contractors. Standing seam panels, trims, flashing, fasteners, sealants, snow retention, and underlayments.",
      "url": "https://fullscopemetals.com",
      "telephone": "+1-970-281-2982",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "5871 Co Hwy 22",
        "addressLocality": "Kremmling",
        "addressRegion": "CO",
        "postalCode": "80459",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 40.0586,
        "longitude": -106.3886
      },
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
        "opens": "07:30",
        "closes": "17:30"
      }],
      "areaServed": {
        "@type": "State",
        "name": "Colorado"
      },
      "founder": {
        "@type": "Person",
        "name": "Matt Johnson"
      },
      "foundingDate": "2024"
    })} />
  </head>
  <body>
    <slot />
    {!isFlashDeckPage && <FlashDeckPopup />}
    <script>
      function initScrollReveal() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.scroll-reveal:not(.revealed)').forEach(el => observer.observe(el));
      }

      if (document.readyState !== 'loading') {
        initScrollReveal();
      } else {
        document.addEventListener('DOMContentLoaded', initScrollReveal);
      }
      document.addEventListener('astro:page-load', initScrollReveal);
    </script>
  </body>
</html>
